{
  "version": 2,
  "status": "active",
  "strategy": "typescript-native-modulith",
  "coverage": {
    "scope": "all-claimed-roots",
    "eslint": "import-bearing-files",
    "audit": "all-claimed-roots"
  },
  "ownershipGranularity": "directory-first-with-explicit-exceptions",
  "compatibilityFacades": "disallowed",
  "entrypointPolicy": {
    "default": "root-first",
    "allowedNamedEntrypoints": ["api.ts", "spi.ts"],
    "workspacePackageExportsArePreferredForRealPackages": true
  },
  "verification": {
    "eslint": {
      "tool": "eslint-plugin-boundaries",
      "primaryRule": "boundaries/dependencies",
      "classificationRule": "boundaries/no-unknown-files",
      "mode": "strict-on-covered-module-roots",
      "ciGate": "pnpm check"
    },
    "dependencyGraph": {
      "tool": "dependency-cruiser",
      "severity": "error",
      "checks": ["no-circular", "allowed-dependencies", "no-deep-cross-module-imports", "package-export-only-access"]
    },
    "manifestAudit": {
      "tool": "scripts/audit-module-boundaries.ts",
      "ciGate": "pnpm check",
      "architectureTest": "apps/backend/test/architecture/module-boundaries-manifest.test.ts"
    }
  },
  "workspaceBoundaries": {
    "@blackbox/web": {
      "level": "workspace-package",
      "packageRoot": "apps/web",
      "packageJson": "apps/web/package.json"
    },
    "@blackbox/backend": {
      "level": "workspace-package",
      "packageRoot": "apps/backend",
      "packageJson": "apps/backend/package.json"
    },
    "@blackbox/api-client": {
      "level": "workspace-package",
      "packageRoot": "packages/api-client",
      "packageJson": "packages/api-client/package.json",
      "ownedRoots": ["packages/api-client/src/**"],
      "exports": {
        ".": "packages/api-client/src/index.ts",
        "./public": "packages/api-client/src/public-client.ts",
        "./internal": "packages/api-client/src/internal-client.ts"
      },
      "deepImportBypassPatterns": ["@blackbox/api-client/src/**", "@blackbox/api-client/src/generated/**"]
    }
  },
  "modules": {
    "app-shell": {
      "status": "open-temporary",
      "temporaryOpenReason": "AppShellRoot is a legacy mixed composition root that still owns shell routing, overlays, history, player coordination, and StoreCart bridge behavior until those seams are characterized and extracted.",
      "exitCriteria": [
        "AppShellRoot becomes a thin composition root over explicit shell seams.",
        "Routing, overlay, history, player coordination, and StoreCart bridge behavior have stable entrypoints and direct coverage.",
        "External callers import only documented shell entrypoints instead of deep helper paths."
      ],
      "forbiddenWhileOpen": [
        "Do not widen app-shell ownership beyond the documented shell roots.",
        "Do not add new open-temporary peer modules as a convenience escape hatch.",
        "Do not introduce temporary compatibility facades for old deep imports."
      ],
      "roots": ["apps/web/src/components/app-shell/**", "apps/web/src/lib/app-shell/**"],
      "providedEntrypoints": ["apps/web/src/components/app-shell/AppShell.astro"],
      "namedInterfaces": {},
      "allowedDependencies": ["player", "store-cart", "checkout-web", "storefront-catalog", "platform-shared"],
      "allowedWorkspaceInterfaces": {},
      "ownershipExceptions": ["apps/web/src/components/app-shell/player-*.ts"]
    },
    "player": {
      "status": "closed",
      "roots": [
        "apps/web/src/components/app-shell/player-*.ts",
        "apps/web/src/components/music/**",
        "apps/web/src/utils/music.ts"
      ],
      "providedEntrypoints": [
        "apps/web/src/components/music/MusicStreamingServiceListenTrigger.astro",
        "apps/web/src/components/app-shell/player-provider-data.ts",
        "apps/web/src/components/app-shell/player-provider-warmup.ts",
        "apps/web/src/components/app-shell/player-iframe-session.ts",
        "apps/web/src/components/app-shell/player-session-machine.ts",
        "apps/web/src/components/app-shell/player-session-ui.ts",
        "apps/web/src/utils/music.ts"
      ],
      "namedInterfaces": {},
      "allowedDependencies": ["platform-shared"],
      "allowedWorkspaceInterfaces": {},
      "ownershipExceptions": []
    },
    "storefront-catalog": {
      "status": "closed",
      "roots": [
        "apps/web/src/lib/site-data.ts",
        "apps/web/src/lib/catalog-data.ts",
        "apps/web/src/lib/distro-data.ts",
        "apps/web/src/lib/store-collection.ts",
        "apps/web/src/lib/store-page-data.ts",
        "apps/web/src/lib/item-availability.ts",
