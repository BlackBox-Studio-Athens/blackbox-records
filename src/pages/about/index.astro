---
import InternalPageHero from '@/components/InternalPageHero.astro';
import NewsletterSignup from '@/components/NewsletterSignup.astro';
import { Card, CardContent } from '@/components/ui/card';
import SiteLayout from '@/layouts/SiteLayout.astro';
import { listArtistProfiles, listReleaseCatalog } from '@/lib/catalog-data';
import { getAboutContent, getLabelSettings } from '@/lib/site-data';
import { calculateCountryCount, calculateYearsActive } from '@/utils/content';

const artistProfiles = await listArtistProfiles();
const releaseCatalogEntries = await listReleaseCatalog();
const [aboutContent, labelSettings] = await Promise.all([getAboutContent(), getLabelSettings()]);
const yearsActive = calculateYearsActive(labelSettings.established_year);
const countryCount = calculateCountryCount(artistProfiles.map((artistProfile) => artistProfile.data.country || ''));
const aboutQuote = aboutContent.quote[0];
---

<SiteLayout pageTitle="About" pageDescription="About the label.">
  <InternalPageHero
    sectionLabel={aboutContent.hero.section_label}
    title={aboutContent.hero.title}
    image={aboutContent.hero.image}
    imageAlt={aboutContent.hero.image_alt}
  />

  <section class="layout-container">
    <Card className="surface-card">
      <CardContent className="p-7 sm:p-10">
        <div class="rich-text-content">
          <p class="font-display text-3xl tracking-[0.06em] uppercase text-foreground">{aboutContent.lead}</p>

          {
            aboutContent.sections.map((sectionItem) => (
              <>
                <h2>{sectionItem.title.toUpperCase()}</h2>
                {sectionItem.paragraphs.map((paragraph) => <p>{paragraph}</p>)}
              </>
            ))
          }

          {
            aboutQuote && (
              <blockquote>
                <p>&quot;{aboutQuote.text}&quot;</p>
                <cite>{aboutQuote.cite}</cite>
              </blockquote>
            )
          }

          <h2>{aboutContent.contact.title.toUpperCase()}</h2>
          <p>{aboutContent.contact.intro}</p>
          <ul>
            {
              aboutContent.contact.items.map((item) => (
                <li>
                  <span class="font-semibold text-foreground">{item.label}:</span> {item.value}
                </li>
              ))
            }
          </ul>
        </div>
      </CardContent>
    </Card>
  </section>

  <section class="layout-container mt-12">
    <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-4">
      {
        aboutContent.stats.map((stat) => {
          let statValue = '';
          if (stat.key === 'artists') statValue = String(artistProfiles.length);
          else if (stat.key === 'releases') statValue = String(releaseCatalogEntries.length);
          else if (stat.key === 'countries') statValue = String(countryCount);
          else if (stat.key === 'year') statValue = String(yearsActive);

          return (
            <Card className="surface-card">
              <CardContent className="space-y-1 p-5">
                <p class="font-display text-4xl tracking-[0.08em] uppercase text-foreground">{statValue}</p>
                <span class="text-xs uppercase tracking-[0.12em] text-muted-foreground">{stat.label}</span>
              </CardContent>
            </Card>
          );
        })
      }
    </div>
  </section>

  <NewsletterSignup formId="about-newsletter-email" />
</SiteLayout>
