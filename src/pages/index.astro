---
import { getCollection } from 'astro:content';

import ArtistCard from '@/components/cards/ArtistCard.astro';
import NewsCard from '@/components/cards/NewsCard.astro';
import ReleaseCard from '@/components/cards/ReleaseCard.astro';
import NewsletterSignup from '@/components/NewsletterSignup.astro';
import SiteLayout from '@/layouts/SiteLayout.astro';
import { createProjectRelativeUrl } from '@/config/site';
import { homeContent } from '@/data/home';
import { calculateCountryCount, calculateYearsActive } from '@/utils/content';

const allArtists = (await getCollection('artists')).sort((left, right) => left.data.title.localeCompare(right.data.title));
const releases = (await getCollection('releases'))
  .slice()
  .sort((left, right) => right.data.release_date.getTime() - left.data.release_date.getTime())
  .slice(0, 3);
const featuredArtists = allArtists.slice(0, 5);
const newsItems = (await getCollection('news'))
  .slice()
  .sort((left, right) => right.data.date.getTime() - left.data.date.getTime())
  .slice(0, 3);

const yearsActive = calculateYearsActive();
const countryCount = calculateCountryCount(allArtists.map((artist) => artist.data.country || ''));

const featuredArtistsJson = JSON.stringify(
  allArtists.map((artist) => ({
    title: artist.data.title,
    slug: artist.data.slug,
    image: artist.data.image,
    image_alt: artist.data.image_alt,
    genre: artist.data.genre,
    bio: artist.data.bio,
  })),
);

const allReleasesCount = (await getCollection('releases')).length;
---

<SiteLayout
  pageTitle="Home"
  pageDescription="BlackBox Records home."
  bodyClass="home-scroll-snap-container"
  mainClass="page-main-content-region--home"
>
  <section class="homepage-hero-section" id="homepage-hero-section">
    <div class="homepage-hero-section__background-pattern-layer" aria-hidden="true">
      <svg viewBox="0 0 100 100" preserveAspectRatio="none" aria-hidden="true">
        <path d="M50 100 Q45 70 50 50 Q55 30 50 0" stroke="currentColor" stroke-width="0.5" fill="none" />
        <path d="M30 100 Q35 60 40 40 Q45 20 50 0" stroke="currentColor" stroke-width="0.3" fill="none" />
        <path d="M70 100 Q65 60 60 40 Q55 20 50 0" stroke="currentColor" stroke-width="0.3" fill="none" />
      </svg>
    </div>
    <div class="homepage-hero-section__orbit-ring-layer homepage-hero-section__orbit-ring-layer--large" aria-hidden="true"></div>
    <div class="homepage-hero-section__orbit-ring-layer homepage-hero-section__orbit-ring-layer--medium" aria-hidden="true"></div>
    <div class="homepage-hero-section__orbit-ring-layer homepage-hero-section__orbit-ring-layer--small" aria-hidden="true"></div>
    <div class="homepage-hero-section__content-block page-content-width-constrained-container">
      <div class="homepage-hero-section__logo-lockup">
        <img src={createProjectRelativeUrl('/assets/images/brand/logo.png')} alt="BlackBox Records" />
      </div>
      <p class="homepage-hero-section__tagline-text">{homeContent.hero.tagline}</p>
      <div class="homepage-hero-section__action-buttons">
        <a class="call-to-action-button call-to-action-button--primary" href={createProjectRelativeUrl(homeContent.hero.primary_button_link)}>
          {homeContent.hero.primary_button_text}
        </a>
        <a class="call-to-action-button call-to-action-button--outline" href={createProjectRelativeUrl(homeContent.hero.secondary_button_link)}>
          {homeContent.hero.secondary_button_text}
        </a>
      </div>
    </div>
    <div class="homepage-hero-section__scroll-indicator" aria-hidden="true">
      <span>Scroll</span>
      <div class="homepage-hero-section__scroll-indicator-line">
        <span></span>
      </div>
    </div>
  </section>

  <section class="page-section-standard-spacing-with-divider" id="featured-releases">
    <div class="page-content-width-constrained-container">
      <div class="page-section-header-layout-spaced">
        <div>
          <p class="page-section-kicker-text">{homeContent.latest_releases.section_label}</p>
          <h2 class="page-section-title-text">{homeContent.latest_releases.title.toUpperCase()}</h2>
        </div>
        <a class="page-section-header-link" href={createProjectRelativeUrl(homeContent.latest_releases.link_url)}>
          {homeContent.latest_releases.link_text} <span aria-hidden="true">&rarr;</span>
        </a>
      </div>
      <div class="release-summary-card-grid">
        {
          releases.map((release) => {
            const artist = allArtists.find((item) => item.data.slug === release.data.artist_slug);
            return <ReleaseCard release={release} artist={artist} />;
          })
        }
      </div>
    </div>
  </section>

  <section class="page-section-standard-spacing-with-divider-and-surface-background" id="artists">
    <div class="page-content-width-constrained-container">
      <div class="page-section-header-layout-centered-and-stacked">
        <p class="page-section-kicker-text">{homeContent.artists.section_label}</p>
        <h2 class="page-section-title-text">{homeContent.artists.title.toUpperCase()}</h2>
      </div>
      <div
        class="artist-roster-card-grid artist-roster-card-grid--featured"
        data-featured-artist-grid
        data-max-items="5"
        data-site-base-url={createProjectRelativeUrl('/')}
      >
        {featuredArtists.map((artist) => <ArtistCard artist={artist} />)}
      </div>
      <script type="application/json" id="homepage-featured-artists-data" set:html={featuredArtistsJson}></script>
      <div class="page-section-call-to-action-region">
        <a class="call-to-action-button call-to-action-button--outline" href={createProjectRelativeUrl(homeContent.artists.button_link)}>
          {homeContent.artists.button_text}
        </a>
      </div>
    </div>
  </section>

  <section class="page-section-standard-spacing-with-divider" id="news">
    <div class="page-content-width-constrained-container">
      <div class="page-section-header-layout-spaced">
        <div>
          <p class="page-section-kicker-text">{homeContent.news.section_label}</p>
          <h2 class="page-section-title-text">{homeContent.news.title.toUpperCase()}</h2>
        </div>
        <a class="page-section-header-link" href={createProjectRelativeUrl(homeContent.news.link_url)}>
          {homeContent.news.link_text} <span aria-hidden="true">&rarr;</span>
        </a>
      </div>
      <div class="news-summary-card-grid">
        {newsItems.map((item) => <NewsCard item={item} />)}
      </div>
    </div>
  </section>

  <section class="page-section-standard-spacing-with-divider-and-surface-background" id="journey">
    <div class="page-content-width-constrained-container about-section-layout-grid">
      <div class="about-section-image-frame">
        <div class="about-section-image-outline"></div>
        <img src={createProjectRelativeUrl(homeContent.journey.image)} alt={homeContent.journey.image_alt} />
      </div>
      <div class="about-section-content-block">
        <p class="page-section-kicker-text">{homeContent.journey.section_label}</p>
        <h2 class="page-section-title-text">{homeContent.journey.title.toUpperCase()}</h2>
        <div class="about-section-body-text">
          {homeContent.journey.paragraphs.map((paragraph) => <p>{paragraph}</p>)}
        </div>
        <div class="about-section-statistics-grid">
          {
            homeContent.journey.stats.map((stat) => {
              const statKey = String(stat.key);
              let statValue = '';
              if (statKey === 'artists') statValue = String(allArtists.length);
              else if (statKey === 'releases') statValue = String(allReleasesCount);
              else if (statKey === 'countries') statValue = String(countryCount);
              else if (statKey === 'year') statValue = String(yearsActive);

              return (
                <div>
                  <p>{statValue}</p>
                  <span>{stat.label}</span>
                </div>
              );
            })
          }
        </div>
      </div>
    </div>
  </section>

  <NewsletterSignup id="newsletter-signup-area" />
</SiteLayout>
