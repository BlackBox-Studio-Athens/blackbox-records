---
import DistroCard from '@/components/cards/DistroCard.astro';
import SiteLayout from '@/layouts/SiteLayout.astro';
import { groupDistroEntries, listDistroEntries } from '@/lib/catalog-data';
import type { DistroGroupName } from '@/lib/distro-data';

const DISTRO_GROUP_INTROS: Record<DistroGroupName, string> = {
  'Distro Picks': 'Things we are backing hard right now, whether they come from BlackBox directly or from the edges of the same circle.',
  'Other Labels': 'Records and small editions from labels we rate, carried because they sit naturally beside what BlackBox is already putting into the world.',
  'Friends & Trades': 'Objects, editions, and trade-table kinds of things that came through the wider network and feel right staying in reach.',
};

const distroEntries = await listDistroEntries();
const groupedDistroEntries = groupDistroEntries(distroEntries);
---

<SiteLayout pageTitle="Distro" pageDescription="Curated distro picks, other labels, and friends & trades.">
  <section class="layout-container distro-page-intro">
    <div class="distro-page-intro__surface">
      <p class="distro-page-intro__eyebrow">Distro</p>
      <h1 class="distro-page-intro__title">Distro</h1>
      <p class="distro-page-intro__copy">
        A small curated layer around the store: things we are backing, things from labels we respect, and things that came in through the same extended network.
      </p>
    </div>
  </section>

  <section class="layout-container distro-page-groups" aria-label="Distro">
    {
      groupedDistroEntries.map((group) => (
        <section class="distro-group-section" aria-labelledby={`distro-group-${group.groupName.toLowerCase().replace(/[^a-z0-9]+/g, '-')}`}>
          <div class="distro-group-section__header">
            <p class="distro-group-section__kicker">Curated Group</p>
            <h2
              class="distro-group-section__title"
              id={`distro-group-${group.groupName.toLowerCase().replace(/[^a-z0-9]+/g, '-')}`}
            >
              {group.groupName}
            </h2>
            <p class="distro-group-section__copy">{DISTRO_GROUP_INTROS[group.groupName]}</p>
          </div>
          <div class="distro-group-grid">
            {group.entries.map((item) => <DistroCard item={item} />)}
          </div>
        </section>
      ))
    }
  </section>
</SiteLayout>
