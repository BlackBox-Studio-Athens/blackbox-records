---
import ReleaseDetailContent from '@/components/detail/ReleaseDetailContent.astro';
import SiteLayout from '@/layouts/SiteLayout.astro';
import {
  createReleaseDetailStaticPaths,
  resolveArtistProfileForRelease,
  resolveReleaseArtistDisplayName,
  type ReleaseCatalogEntry,
} from '@/lib/catalog-data';

export async function getStaticPaths() {
  return createReleaseDetailStaticPaths();
}

interface Props {
  release: ReleaseCatalogEntry;
}

const { release } = Astro.props;
const releaseArtist = await resolveArtistProfileForRelease(release);
const artistName = resolveReleaseArtistDisplayName(release, releaseArtist);
---

<SiteLayout
  pageTitle={release.data.title}
  pageDescription={release.data.summary || `${release.data.title} by ${artistName}`}
  coverImage={release.data.cover_image}
  coverImageAlt={release.data.cover_image_alt || release.data.title}
>
  <ReleaseDetailContent release={release} />
</SiteLayout>
