---
import ArtistDetailContent from '@/components/detail/ArtistDetailContent.astro';
import SiteLayout from '@/layouts/SiteLayout.astro';
import { createArtistDetailStaticPaths, type ArtistProfileEntry } from '@/lib/catalog-data';

export async function getStaticPaths() {
  return createArtistDetailStaticPaths();
}

interface Props {
  artist: ArtistProfileEntry;
}

const { artist } = Astro.props;
const artistName = artist.data.title || 'Artist';
---

<SiteLayout
  pageTitle={artistName}
  pageDescription={artist.data.bio}
  image={artist.data.image}
  imageAlt={artist.data.image_alt || artistName}
>
  <ArtistDetailContent artist={artist} />
</SiteLayout>
