---
import { getCollection } from 'astro:content';

import ArtistCard from '@/components/cards/ArtistCard.astro';
import InternalPageHero from '@/components/InternalPageHero.astro';
import SiteLayout from '@/layouts/SiteLayout.astro';

const artists = (await getCollection('artists')).sort((left, right) => left.data.title.localeCompare(right.data.title));
---

<SiteLayout pageTitle="Artists" pageDescription="Artists roster.">
  <InternalPageHero sectionLabel="Roster" title="Artists" />
  <section class="page-section-compact-spacing">
    <div class="page-content-width-constrained-container">
      <div class="artist-roster-card-grid">
        {artists.map((artist) => <ArtistCard artist={artist} />)}
      </div>
    </div>
  </section>
</SiteLayout>
