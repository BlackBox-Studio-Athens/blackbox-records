---
import AppShellRoot from '@/components/app-shell/AppShellRoot';
import { getContentSection, getHeaderNavigationItems, getLabelSettings, getServicesContent } from '@/lib/site-data';

const [mobileNavigationItems, labelSettings, servicesContent] = await Promise.all([
  getHeaderNavigationItems(),
  getLabelSettings(),
  getServicesContent(),
]);
const servicesInquirySection = getContentSection(servicesContent.sections, 'inquiry');
---

<AppShellRoot
  client:load
  mobileNavigationItems={mobileNavigationItems}
  servicesInquiryEmail={servicesInquirySection?.email || ''}
  servicesInquirySubmitText={servicesInquirySection?.submit_text || 'Compose Inquiry'}
  siteTitle={labelSettings.label_name}
/>
