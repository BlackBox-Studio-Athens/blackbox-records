---
import { buttonVariants } from '@/components/ui/button';
import { createProjectRelativeUrl, resolveLinkAttributes } from '@/config/site';
import { cn } from '@/lib/utils';

interface Props {
  tagline: string;
  primaryButtonText: string;
  primaryButtonLink: string;
  secondaryButtonText: string;
  secondaryButtonLink: string;
  scrollIndicatorText?: string;
  logoAlt?: string;
  logoSrc?: string;
}

const {
  tagline,
  primaryButtonText,
  primaryButtonLink,
  secondaryButtonText,
  secondaryButtonLink,
  scrollIndicatorText = 'Scroll',
  logoAlt = 'BlackBox Records',
  logoSrc = createProjectRelativeUrl('/assets/images/brand/logo.png'),
} = Astro.props;

const heroPrimaryButtonClass = cn(
  buttonVariants(),
  'homepage-hero-section__cta-button homepage-hero-section__cta-button--primary h-[47.8125px] rounded-none px-10 py-4 text-[12px] tracking-[0.2em] uppercase hover:!text-primary-foreground focus-visible:!text-primary-foreground',
);

const heroSecondaryButtonClass = cn(
  buttonVariants({ variant: 'outline' }),
  'homepage-hero-section__cta-button homepage-hero-section__cta-button--outline h-[47.8125px] rounded-none px-10 py-4 text-[12px] tracking-[0.2em] uppercase !border-foreground !text-foreground hover:!border-foreground hover:!bg-foreground hover:!text-primary-foreground focus-visible:!border-foreground focus-visible:!bg-foreground focus-visible:!text-primary-foreground',
);

const primaryButtonLinkAttributes = resolveLinkAttributes(primaryButtonLink);
const secondaryButtonLinkAttributes = resolveLinkAttributes(secondaryButtonLink);
---

<section class="homepage-hero-section border-b border-border/70" id="homepage-hero-section">
  <div class="homepage-hero-section__background-pattern-layer" aria-hidden="true">
    <svg viewBox="0 0 1200 900" preserveAspectRatio="none">
      <defs>
        <pattern id="hero-grid-dot-pattern" width="28" height="28" patternUnits="userSpaceOnUse">
          <circle cx="1.25" cy="1.25" r="1.25" fill="currentColor"></circle>
        </pattern>
      </defs>
      <rect width="1200" height="900" fill="url(#hero-grid-dot-pattern)"></rect>
    </svg>
  </div>

  <div class="homepage-hero-section__orbit-ring-layer homepage-hero-section__orbit-ring-layer--large" aria-hidden="true"></div>
  <div class="homepage-hero-section__orbit-ring-layer homepage-hero-section__orbit-ring-layer--medium" aria-hidden="true"></div>
  <div class="homepage-hero-section__orbit-ring-layer homepage-hero-section__orbit-ring-layer--small" aria-hidden="true"></div>

  <div class="homepage-hero-section__content-block page-content-width-constrained-container">
    <h1 class="sr-only">BlackBox Records</h1>
    <div class="homepage-hero-section__logo-lockup">
      <img src={logoSrc} alt={logoAlt} />
    </div>

    <p class="homepage-hero-section__tagline-text">{tagline}</p>

    <div class="homepage-hero-section__action-buttons">
      <a
        href={primaryButtonLinkAttributes.href}
        target={primaryButtonLinkAttributes.target}
        rel={primaryButtonLinkAttributes.rel}
        data-astro-prefetch={primaryButtonLinkAttributes.shouldPrefetch ? true : undefined}
        class={heroPrimaryButtonClass}
      >
        {primaryButtonText}
      </a>
      <a
        href={secondaryButtonLinkAttributes.href}
        target={secondaryButtonLinkAttributes.target}
        rel={secondaryButtonLinkAttributes.rel}
        data-astro-prefetch={secondaryButtonLinkAttributes.shouldPrefetch ? true : undefined}
        class={heroSecondaryButtonClass}
      >
        {secondaryButtonText}
      </a>
    </div>
  </div>

  <div class="homepage-hero-section__scroll-indicator" aria-hidden="true">
    <span>{scrollIndicatorText}</span>
    <div class="homepage-hero-section__scroll-indicator-line">
      <span></span>
    </div>
  </div>
</section>
