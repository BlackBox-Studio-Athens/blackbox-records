generator client {
  provider   = "prisma-client"
  output     = "../src/generated/prisma"
  runtime    = "cloudflare"
  engineType = "client"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

enum StoreItemSourceKind {
  release
  distro
}

enum ItemAvailabilityStatus {
  available
  sold_out
}

model StoreItemOption {
  id            String              @id @default(cuid())
  storeItemSlug String              @unique
  sourceKind    StoreItemSourceKind
  sourceId      String
  variantId     String              @unique
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt

  @@unique([sourceKind, sourceId])
}

model VariantStripeMapping {
  id            String   @id @default(cuid())
  variantId     String   @unique
  stripePriceId String
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model ItemAvailability {
  id        String                 @id @default(cuid())
  variantId String                 @unique
  status    ItemAvailabilityStatus
  canBuy    Boolean
  updatedAt DateTime               @updatedAt
}

model Stock {
  id             String   @id @default(cuid())
  variantId      String   @unique
  quantity       Int
  onlineQuantity Int
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model StockChange {
  id            String   @id @default(cuid())
  variantId     String
  quantityDelta Int
  reason        String
  notes         String?
  actorEmail    String
  recordedAt    DateTime @default(now())

  @@index([variantId, recordedAt])
}

model StockCount {
  id              String   @id @default(cuid())
  variantId       String
  countedQuantity Int
  onlineQuantity  Int
  notes           String?
  actorEmail      String
  recordedAt      DateTime @default(now())

  @@index([variantId, recordedAt])
}
