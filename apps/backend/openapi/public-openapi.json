{
  "openapi": "3.1.0",
  "info": {
    "title": "BlackBox Records Public API",
    "version": "1.0.0"
  },
  "components": {
    "schemas": {
      "StoreCapabilities": {
        "type": "object",
        "properties": {
          "nativeCheckout": {
            "type": "object",
            "properties": {
              "enabled": {
                "type": "boolean"
              },
              "unavailableReason": {
                "anyOf": [
                  {
                    "type": "string"
                  },
                  {
                    "type": "null"
                  }
                ]
              }
            },
            "required": [
              "enabled",
              "unavailableReason"
            ]
          }
        },
        "required": [
          "nativeCheckout"
        ]
      },
      "PublicStoreOffer": {
        "type": "object",
        "properties": {
          "availability": {
            "$ref": "#/components/schemas/PublicStoreOfferAvailability"
          },
          "canCheckout": {
            "type": "boolean"
          },
          "catalogStatus": {
            "type": "string",
            "enum": [
              "catalog_drift",
              "ready",
              "sold_out"
            ]
          },
          "price": {
            "anyOf": [
              {
                "$ref": "#/components/schemas/PublicStoreOfferPrice"
              },
              {
                "type": "null"
              }
            ]
          },
          "storeItemSlug": {
            "type": "string"
          },
          "variantId": {
            "type": "string"
          }
        },
        "required": [
          "availability",
          "canCheckout",
          "catalogStatus",
          "price",
          "storeItemSlug",
          "variantId"
        ]
      },
      "PublicStoreOfferAvailability": {
        "type": "object",
        "properties": {
          "label": {
            "type": "string"
          },
          "status": {
            "type": "string",
            "enum": [
              "available",
              "sold_out"
            ]
          }
        },
        "required": [
          "label",
          "status"
        ]
      },
      "PublicStoreOfferPrice": {
        "type": "object",
        "properties": {
          "amountMinor": {
            "type": "integer",
            "minimum": 0
          },
          "currencyCode": {
            "type": "string",
            "minLength": 3,
            "maxLength": 3
          },
          "display": {
            "type": "string"
          }
        },
        "required": [
          "amountMinor",
          "currencyCode",
          "display"
        ]
      },
      "PublicCommerceError": {
        "type": "object",
        "properties": {
          "error": {
            "type": "string"
          }
        },
        "required": [
          "error"
        ]
      },
      "StartCheckoutResponse": {
        "type": "object",
        "properties": {
          "checkoutUrl": {
            "type": "string",
            "format": "uri"
          }
        },
        "required": [
          "checkoutUrl"
        ]
      },
      "StartCheckoutBody": {
        "type": "object",
        "properties": {
          "lines": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/StartCheckoutLine"
            },
            "minItems": 1
          },
          "newsletterOptIn": {
            "type": "boolean"
          },
          "storeItemSlug": {
            "type": "string",
            "minLength": 1
          },
          "variantId": {
            "type": "string",
            "minLength": 1
          }
        },
        "additionalProperties": false
      },
      "StartCheckoutLine": {
        "type": "object",
        "properties": {
          "quantity": {
            "type": "integer",
            "minimum": 1,
            "maximum": 9
          },
          "storeItemSlug": {
            "type": "string",
            "minLength": 1
          },
          "variantId": {
            "type": "string",
            "minLength": 1
          }
        },
        "required": [
          "quantity",
          "storeItemSlug",
          "variantId"
        ],
        "additionalProperties": false
      },
      "CheckoutState": {
        "type": "object",
        "properties": {
          "checkoutSessionId": {
            "type": "string"
          },
          "paymentStatus": {
            "type": "string",
            "enum": [
              "paid",
              "unpaid",
              "no_payment_required"
            ]
          },
          "shippingLocker": {
            "anyOf": [
              {
                "$ref": "#/components/schemas/CheckoutStateShippingLocker"
              },
              {
                "type": "null"
              }
            ]
          },
          "state": {
            "type": "string",
            "enum": [
              "open",
              "paid",
              "processing",
              "expired",
              "unknown"
            ]
          },
          "status": {
            "type": [
              "string",
              "null"
            ],
            "enum": [
              "open",
              "complete",
              "expired",
              null
            ]
          }
        },
        "required": [
          "checkoutSessionId",
          "paymentStatus",
          "shippingLocker",
          "state",
          "status"
        ]
      },
      "CheckoutStateShippingLocker": {
        "type": "object",
        "properties": {
          "country_code": {
            "type": "string",
            "enum": [
              "GR"
            ]
          },
          "locker_id": {
            "type": "string",
            "minLength": 1
          },
          "locker_name_or_label": {
            "type": "string",
            "minLength": 1
          }
        },
        "required": [
          "country_code",
          "locker_id",
          "locker_name_or_label"
        ]
      },
      "NewsletterRegistrationResponse": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string",
            "enum": [
              "registered"
            ]
          }
        },
        "required": [
          "status"
        ]
      },
      "NewsletterRegistrationBody": {
        "type": "object",
        "properties": {
          "consentAccepted": {
            "type": "boolean",
            "enum": [
              true
            ]
          },
          "email": {
            "type": "string",
            "format": "email"
          }
        },
        "required": [
          "consentAccepted",
          "email"
        ],
        "additionalProperties": false
      }
    },
    "parameters": {}
  },
  "paths": {
    "/api/store/capabilities": {
      "get": {
        "tags": [
          "Store"
        ],
        "responses": {
          "200": {
            "description": "Browser-safe public store capability state.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/StoreCapabilities"
                }
              }
            }
          }
        }
      }
    },
    "/api/store/items/{storeItemSlug}": {
      "get": {
        "tags": [
          "Store"
        ],
        "parameters": [
          {
            "schema": {
              "type": "string",
              "minLength": 1
            },
            "required": true,
            "name": "storeItemSlug",
            "in": "path"
          }
        ],
        "responses": {
          "200": {
            "description": "Backend-known checkout eligibility for one store item.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/PublicStoreOffer"
                }
              }
            }
          },
          "404": {
            "description": "Store item not found.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/PublicCommerceError"
                }
              }
            }
          }
        }
      }
    },
    "/api/store/items/{storeItemSlug}/variants": {
      "get": {
        "tags": [
          "Store"
        ],
        "parameters": [
          {
            "schema": {
              "type": "string",
              "minLength": 1
            },
            "required": true,
            "name": "storeItemSlug",
            "in": "path"
          }
        ],
        "responses": {
          "200": {
            "description": "Checkout-eligible variants for one store item.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/PublicStoreOffer"
                  }
                }
              }
            }
          },
          "404": {
            "description": "Store item not found.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/PublicCommerceError"
                }
              }
            }
          }
        }
      }
    },
    "/api/checkout/sessions": {
      "post": {
        "tags": [
          "Checkout"
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/StartCheckoutBody"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Created a hosted Stripe Checkout Session.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/StartCheckoutResponse"
                }
              }
            }
          },
          "400": {
            "description": "Invalid checkout request.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/PublicCommerceError"
                }
              }
            }
          },
          "404": {
            "description": "Store item not found.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/PublicCommerceError"
                }
              }
            }
          },
          "409": {
            "description": "Checkout unavailable or not configured.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/PublicCommerceError"
                }
              }
            }
          },
          "503": {
            "description": "Native checkout is temporarily unavailable.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/PublicCommerceError"
                }
              }
            }
          }
        }
      }
    },
    "/api/checkout/sessions/{checkoutSessionId}/state": {
      "get": {
        "tags": [
          "Checkout"
        ],
        "parameters": [
          {
            "schema": {
              "type": "string",
              "minLength": 1
            },
            "required": true,
            "name": "checkoutSessionId",
            "in": "path"
          }
        ],
        "responses": {
          "200": {
            "description": "Sanitized Checkout Session state for shopper return UI.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/CheckoutState"
                }
              }
            }
          },
          "409": {
            "description": "Checkout is not configured.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/PublicCommerceError"
                }
              }
            }
          }
        }
      }
    },
    "/api/newsletter/registrations": {
      "post": {
        "tags": [
          "Newsletter"
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/NewsletterRegistrationBody"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Registered a public newsletter contact.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/NewsletterRegistrationResponse"
                }
              }
            }
          },
          "400": {
            "description": "Invalid newsletter signup request.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/PublicCommerceError"
                }
              }
            }
          },
          "503": {
            "description": "Newsletter signup is temporarily unavailable.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/PublicCommerceError"
                }
              }
            }
          }
        }
      }
    }
  },
  "webhooks": {}
}
