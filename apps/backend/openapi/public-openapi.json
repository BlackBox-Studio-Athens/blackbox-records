{
  "openapi": "3.1.0",
  "info": {
    "title": "BlackBox Records Public API",
    "version": "1.0.0"
  },
  "components": {
    "schemas": {
      "StoreCapabilities": {
        "type": "object",
        "properties": {
          "nativeCheckout": {
            "type": "object",
            "properties": {
              "enabled": {
                "type": "boolean"
              },
              "unavailableReason": {
                "anyOf": [
                  {
                    "type": "string"
                  },
                  {
                    "type": "null"
                  }
                ]
              }
            },
            "required": [
              "enabled",
              "unavailableReason"
            ]
          }
        },
        "required": [
          "nativeCheckout"
        ]
      },
      "PublicStoreListingPrice": {
        "oneOf": [
          {
            "type": "object",
            "properties": {
              "displayPrice": {
                "type": "string",
                "minLength": 1
              },
              "presentationState": {
                "type": "string",
                "enum": [
                  "ready"
                ]
              },
              "storeItemSlug": {
                "type": "string",
                "minLength": 1
              }
            },
            "required": [
              "displayPrice",
              "presentationState",
              "storeItemSlug"
            ]
          },
          {
            "type": "object",
            "properties": {
              "presentationState": {
                "type": "string",
                "enum": [
                  "unavailable"
                ]
              },
              "storeItemSlug": {
                "type": "string",
                "minLength": 1
              }
            },
            "required": [
              "presentationState",
              "storeItemSlug"
            ]
          }
        ]
      },
      "PublicStoreOffer": {
        "oneOf": [
          {
            "type": "object",
            "properties": {
              "storeItemSlug": {
                "type": "string"
              },
              "variantId": {
                "type": "string"
              },
              "availability": {
                "type": "object",
                "properties": {
                  "label": {
                    "type": "string"
                  },
                  "status": {
                    "type": "string",
                    "enum": [
                      "available"
                    ]
                  }
                },
                "required": [
                  "label",
                  "status"
                ]
              },
              "canCheckout": {
                "type": "boolean",
                "enum": [
                  true
                ]
              },
              "catalogStatus": {
                "type": "string",
                "enum": [
                  "ready"
                ]
              },
              "price": {
                "$ref": "#/components/schemas/PublicStoreOfferPrice"
              }
            },
            "required": [
              "storeItemSlug",
              "variantId",
              "availability",
              "canCheckout",
              "catalogStatus",
              "price"
            ]
          },
          {
            "type": "object",
            "properties": {
              "storeItemSlug": {
                "type": "string"
              },
              "variantId": {
                "type": "string"
              },
              "availability": {
                "type": "object",
                "properties": {
                  "label": {
                    "type": "string"
                  },
                  "status": {
                    "type": "string",
                    "enum": [
                      "sold_out"
                    ]
                  }
                },
                "required": [
                  "label",
                  "status"
                ]
              },
              "canCheckout": {
                "type": "boolean",
                "enum": [
                  false
                ]
              },
              "catalogStatus": {
                "type": "string",
                "enum": [
                  "sold_out"
                ]
              },
              "price": {
                "type": "null"
              }
            },
            "required": [
              "storeItemSlug",
              "variantId",
              "availability",
              "canCheckout",
              "catalogStatus",
              "price"
            ]
          },
          {
            "type": "object",
            "properties": {
              "storeItemSlug": {
                "type": "string"
              },
              "variantId": {
                "type": "string"
              },
              "availability": {
                "type": "object",
                "properties": {
                  "label": {
                    "type": "string"
                  },
                  "status": {
                    "type": "string",
                    "enum": [
                      "unavailable"
                    ]
                  }
                },
                "required": [
                  "label",
                  "status"
                ]
              },
              "canCheckout": {
                "type": "boolean",
                "enum": [
                  false
                ]
              },
              "catalogStatus": {
                "type": "string",
                "enum": [
                  "catalog_drift"
                ]
              },
              "price": {
                "type": "null"
              }
            },
            "required": [
              "storeItemSlug",
              "variantId",
              "availability",
              "canCheckout",
              "catalogStatus",
              "price"
            ]
          }
        ]
      },
      "PublicStoreOfferPrice": {
        "oneOf": [
          {
            "type": "object",
            "properties": {
              "amountMinor": {
                "type": "integer",
                "minimum": 0
              },
              "currencyCode": {
                "type": "string",
                "minLength": 3,
                "maxLength": 3
              },
              "display": {
                "type": "string"
              },
              "kind": {
                "type": "string",
                "enum": [
                  "fixed"
                ]
              }
            },
            "required": [
              "amountMinor",
              "currencyCode",
              "display",
              "kind"
            ]
          },
          {
            "type": "object",
            "properties": {
              "currencyCode": {
                "type": "string",
                "minLength": 3,
                "maxLength": 3
              },
              "display": {
                "type": "string"
              },
              "kind": {
                "type": "string",
                "enum": [
                  "pay_what_you_want"
                ]
              },
              "maximumAmountMinor": {
                "type": "integer",
                "exclusiveMinimum": 0
              },
              "minimumAmountMinor": {
                "type": "integer",
                "exclusiveMinimum": 0
              },
              "presetAmountMinor": {
                "type": "integer",
                "exclusiveMinimum": 0
              }
            },
            "required": [
              "currencyCode",
              "display",
              "kind",
              "maximumAmountMinor",
              "minimumAmountMinor",
              "presetAmountMinor"
            ]
          }
        ]
      },
      "BackendErrorResponse": {
        "type": "object",
        "properties": {
          "code": {
            "type": "string",
            "pattern": "^[a-z][a-z0-9_]*$"
          },
          "error": {
            "type": "string"
          },
          "requestId": {
            "type": "string",
            "minLength": 1
          }
        },
        "required": [
          "code",
          "error"
        ]
      },
      "StartCheckoutResponse": {
        "type": "object",
        "properties": {
          "checkoutUrl": {
            "type": "string",
            "format": "uri"
          }
        },
        "required": [
          "checkoutUrl"
        ]
      },
      "StartCheckoutBody": {
        "type": "object",
        "properties": {
          "lines": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/StartCheckoutLine"
            },
            "minItems": 1
          },
          "newsletterOptIn": {
            "type": "boolean"
          },
          "storeItemSlug": {
            "type": "string",
            "minLength": 1
          },
          "variantId": {
            "type": "string",
            "minLength": 1
          }
        },
        "additionalProperties": false
      },
      "StartCheckoutLine": {
        "type": "object",
        "properties": {
          "quantity": {
            "type": "integer",
            "minimum": 1,
            "maximum": 9
          },
          "storeItemSlug": {
            "type": "string",
            "minLength": 1
          },
          "variantId": {
            "type": "string",
            "minLength": 1
          }
        },
        "required": [
          "quantity",
          "storeItemSlug",
          "variantId"
        ],
        "additionalProperties": false
      },
      "CheckoutState": {
        "type": "object",
        "properties": {
          "checkoutSessionId": {
            "type": "string"
          },
          "orderStatus": {
            "type": [
              "string",
              "null"
            ],
            "enum": [
              "pending_payment",
              "paid",
              "not_paid",
              "needs_review",
              null
            ]
          },
          "paymentStatus": {
            "type": "string",
            "enum": [
              "paid",
              "unpaid",
              "no_payment_required"
            ]
          },
          "shippingLocker": {
            "anyOf": [
              {
                "$ref": "#/components/schemas/CheckoutStateShippingLocker"
              },
              {
                "type": "null"
              }
            ]
          },
          "state": {
            "type": "string",
            "enum": [
              "open",
              "paid",
              "processing",
              "expired",
              "unknown"
            ]
          },
          "status": {
            "type": [
              "string",
              "null"
            ],
            "enum": [
              "open",
              "complete",
              "expired",
              null
            ]
          }
        },
        "required": [
          "checkoutSessionId",
          "orderStatus",
          "paymentStatus",
          "shippingLocker",
          "state",
          "status"
        ]
      },
      "CheckoutStateShippingLocker": {
        "type": "object",
        "properties": {
          "country_code": {
            "type": "string",
            "enum": [
              "GR"
            ]
          },
          "locker_id": {
            "type": "string",
            "minLength": 1
          },
          "locker_name_or_label": {
            "type": "string",
            "minLength": 1
          }
        },
        "required": [
          "country_code",
          "locker_id",
          "locker_name_or_label"
        ]
      },
      "NewsletterRegistrationResponse": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string",
            "enum": [
              "registered"
            ]
          }
        },
        "required": [
          "status"
        ]
      },
      "NewsletterRegistrationBody": {
        "type": "object",
        "properties": {
          "consentAccepted": {
            "type": "boolean",
            "enum": [
              true
            ]
          },
          "email": {
            "type": "string",
            "format": "email"
          }
        },
        "required": [
          "consentAccepted",
          "email"
        ],
        "additionalProperties": false
      },
      "ServicesInquiryResponse": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string",
            "enum": [
              "submitted"
            ]
          }
        },
        "required": [
          "status"
        ],
        "additionalProperties": false
      },
      "ServicesInquiryBody": {
        "type": "object",
        "properties": {
          "bandOrProject": {
            "type": "string",
            "maxLength": 160
          },
          "email": {
            "type": "string",
            "maxLength": 254,
            "format": "email"
          },
          "message": {
            "type": "string",
            "minLength": 1,
            "maxLength": 2000
          },
          "name": {
            "type": "string",
            "minLength": 1,
            "maxLength": 100
          },
          "service": {
            "type": "string",
            "enum": [
              "General",
              "Tour Booking",
              "Merch Printing",
              "Vinyl Printing"
            ]
          },
          "serviceDetails": {
            "type": "string",
            "maxLength": 300
          }
        },
        "required": [
          "email",
          "message",
          "name",
          "service"
        ],
        "additionalProperties": false
      }
    },
    "parameters": {}
  },
  "paths": {
    "/api/store/capabilities": {
      "get": {
        "tags": [
          "Store"
        ],
        "responses": {
          "200": {
            "description": "Browser-safe public store capability state.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/StoreCapabilities"
                }
              }
            }
          }
        }
      }
    },
    "/api/store/listing-prices": {
      "get": {
        "tags": [
          "Store"
        ],
        "responses": {
          "200": {
            "description": "Browser-safe current Store listing-price presentation.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/PublicStoreListingPrice"
                  }
                }
              }
            }
          }
        }
      }
    },
    "/api/store/items/{storeItemSlug}": {
      "get": {
        "tags": [
          "Store"
        ],
        "parameters": [
          {
            "schema": {
              "type": "string",
              "minLength": 1
            },
            "required": true,
            "name": "storeItemSlug",
            "in": "path"
          }
        ],
        "responses": {
          "200": {
            "description": "Backend-known checkout eligibility for one store item.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/PublicStoreOffer"
                }
              }
            }
          },
          "404": {
            "description": "Store item not found.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/BackendErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/api/store/items/{storeItemSlug}/variants": {
      "get": {
        "tags": [
          "Store"
        ],
        "parameters": [
          {
            "schema": {
              "type": "string",
              "minLength": 1
            },
            "required": true,
            "name": "storeItemSlug",
            "in": "path"
          }
        ],
        "responses": {
          "200": {
            "description": "Checkout-eligible variants for one store item.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/PublicStoreOffer"
                  }
                }
              }
            }
          },
          "404": {
            "description": "Store item not found.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/BackendErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/api/checkout/sessions": {
      "post": {
        "tags": [
          "Checkout"
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/StartCheckoutBody"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Created a hosted Stripe Checkout Session.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/StartCheckoutResponse"
                }
              }
            }
          },
          "400": {
            "description": "Invalid checkout request.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/BackendErrorResponse"
                }
              }
            }
          },
          "404": {
            "description": "Store item not found.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/BackendErrorResponse"
                }
              }
            }
          },
          "409": {
            "description": "Checkout unavailable or not configured.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/BackendErrorResponse"
                }
              }
            }
          },
          "503": {
            "description": "Native checkout is temporarily unavailable.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/BackendErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/api/checkout/sessions/{checkoutSessionId}/state": {
      "get": {
        "tags": [
          "Checkout"
        ],
        "parameters": [
          {
            "schema": {
              "type": "string",
              "minLength": 1
            },
            "required": true,
            "name": "checkoutSessionId",
            "in": "path"
          }
        ],
        "responses": {
          "200": {
            "description": "Sanitized Checkout Session state for shopper return UI.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/CheckoutState"
                }
              }
            }
          },
          "409": {
            "description": "Checkout is not configured.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/BackendErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/api/newsletter/registrations": {
      "post": {
        "tags": [
          "Newsletter"
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/NewsletterRegistrationBody"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Registered a public newsletter contact.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/NewsletterRegistrationResponse"
                }
              }
            }
          },
          "400": {
            "description": "Invalid newsletter signup request.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/BackendErrorResponse"
                }
              }
            }
          },
          "503": {
            "description": "Newsletter signup is temporarily unavailable.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/BackendErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/api/services/inquiries": {
      "post": {
        "tags": [
          "Services"
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/ServicesInquiryBody"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Submitted a Services inquiry for provider delivery.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ServicesInquiryResponse"
                }
              }
            }
          },
          "400": {
            "description": "Invalid Services inquiry request.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/BackendErrorResponse"
                }
              }
            }
          },
          "503": {
            "description": "Services inquiry submission is temporarily unavailable.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/BackendErrorResponse"
                }
              }
            }
          }
        }
      }
    }
  },
  "webhooks": {}
}
