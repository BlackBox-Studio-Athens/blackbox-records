{
  "name": "@blackbox/backend",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "wrangler dev",
    "dev:mock": "wrangler dev --env mock",
    "dev:mock-api": "wrangler dev --env mock-api",
    "dev:uat": "wrangler dev --env uat",
    "dev:sandbox": "pnpm dev:uat",
    "deploy:uat": "wrangler deploy --env uat",
    "deploy:sandbox": "pnpm deploy:uat",
    "deploy:prd": "wrangler deploy --env prd",
    "deploy:production": "pnpm deploy:prd",
    "d1:smoke:local": "wrangler d1 execute COMMERCE_DB --local --command \"SELECT 1 AS ok\" --json",
    "d1:seed:local": "wrangler d1 execute COMMERCE_DB --local --file ./prisma/seeds/local-commerce-state.sql --json",
    "d1:seed:uat": "wrangler d1 execute COMMERCE_DB --env uat --remote --file ./prisma/seeds/local-commerce-state.sql --json",
    "d1:seed:sandbox": "pnpm d1:seed:uat",
    "d1:seed:uat:catalog": "wrangler d1 execute COMMERCE_DB --env uat --remote --file ./prisma/seeds/uat-commerce-state.sql --json",
    "d1:seed:sandbox:uat-catalog": "pnpm d1:seed:uat:catalog",
    "d1:seed:prd:catalog-readiness": "wrangler d1 execute COMMERCE_DB --env prd --remote --file ./prisma/seeds/prd-commerce-readiness.sql --json",
    "d1:seed:production:catalog-readiness": "pnpm d1:seed:prd:catalog-readiness",
    "d1:seed:stripe-mock:local": "tsx scripts/seed-local-mock-commerce-state.ts",
    "d1:check:stripe-mock:local": "tsx scripts/check-local-mock-commerce-readiness.ts",
    "d1:seed:stripe-test:local": "node scripts/apply-local-stripe-test-seed.mjs",
    "d1:prepare:local": "pnpm d1:migrations:apply:local && pnpm d1:seed:local && pnpm d1:smoke:local",
    "d1:migrations:create": "wrangler d1 migrations create COMMERCE_DB",
    "d1:migrations:list:local": "wrangler d1 migrations list COMMERCE_DB --local",
    "d1:migrations:apply:local": "wrangler d1 migrations apply COMMERCE_DB --local",
    "d1:migrations:list:uat": "wrangler d1 migrations list COMMERCE_DB --env uat --remote",
    "d1:migrations:list:sandbox": "pnpm d1:migrations:list:uat",
    "d1:migrations:apply:uat": "wrangler d1 migrations apply COMMERCE_DB --env uat --remote",
    "d1:migrations:apply:sandbox": "pnpm d1:migrations:apply:uat",
    "d1:migrations:list:prd": "wrangler d1 migrations list COMMERCE_DB --env prd --remote",
    "d1:migrations:list:production": "pnpm d1:migrations:list:prd",
    "d1:migrations:apply:prd": "wrangler d1 migrations apply COMMERCE_DB --env prd --remote",
    "d1:migrations:apply:production": "pnpm d1:migrations:apply:prd",
    "prisma:generate": "pnpm exec prisma generate",
    "generate:openapi": "pnpm exec tsx scripts/generate-openapi.ts",
    "webhook:simulate:local": "tsx scripts/simulate-stripe-webhook.ts",
    "check": "tsc --noEmit -p tsconfig.json",
    "test": "vitest run --config vitest.config.ts && vitest run --config vitest.node.config.ts",
    "test:node": "vitest run --config vitest.node.config.ts"
  },
  "dependencies": {
    "@cloudflare/flagship": "0.3.1",
    "@hono/zod-openapi": "^1.4.0",
    "@openfeature/server-sdk": "1.21.0",
    "@prisma/adapter-d1": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "hono": "4.12.22",
    "resend": "^6.12.4",
    "stripe": "^22.1.1",
    "unique-names-generator": "^4.7.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@cloudflare/vitest-pool-workers": "^0.16.9",
    "@cloudflare/workers-types": "^4.20260523.1",
    "@types/node": "^25.9.1",
    "prisma": "^7.8.0",
    "tsx": "4.22.4",
    "typescript": "^5.9.3",
    "vitest": "4.1.7",
    "wrangler": "^4.94.0"
  }
}
