---
import { Card, CardContent, CardHeader, CardTitle } from '@/components/ui/card';
import NewsletterSignupForm from '@/components/NewsletterSignupForm';
import { getNewsletterContent } from '@/lib/site-data';

interface Props {
  id?: string;
  formId?: string;
}

const { id, formId = 'newsletter-email' } = Astro.props;
const newsletterContent = await getNewsletterContent();
---

<section class="layout-container mt-16" id={id}>
  <div class="border border-border/70 bg-card/45">
    <Card className="border-none bg-transparent shadow-none">
      <CardHeader className="pb-2">
        <p class="text-xs tracking-[0.2em] text-muted-foreground uppercase">{newsletterContent.section_label}</p>
        <CardTitle className="font-display text-4xl tracking-[0.09em] uppercase"
          >{newsletterContent.title.toUpperCase()}</CardTitle
        >
      </CardHeader>
      <CardContent className="pb-8">
        <p class="max-w-2xl text-sm leading-relaxed text-muted-foreground">{newsletterContent.description}</p>
        <NewsletterSignupForm
          client:load
          buttonLabel={newsletterContent.button_label}
          formId={formId}
          note={newsletterContent.note}
          placeholder={newsletterContent.placeholder}
        />
      </CardContent>
    </Card>
  </div>
</section>
