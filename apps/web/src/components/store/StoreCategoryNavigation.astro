---
import { createProjectRelativeUrl } from '@/config/site';
import { getDiscoverableStoreCatalogCategories, type StoreCatalogCategoryId } from '@/lib/store-categories';
import { listStoreCollectionEntries } from '@/lib/store-collection';

interface Props {
  activeCategoryId: StoreCatalogCategoryId;
}

const { activeCategoryId } = Astro.props;
const allEntries = await listStoreCollectionEntries();
const discoverableCategories = getDiscoverableStoreCatalogCategories([
  'all',
  ...allEntries.flatMap((entry) => entry.categoryIds),
]);
---

<nav aria-label="Store categories" class="store-category-signal">
  <ul
    class="layout-container store-category-signal__list"
    style={`--store-category-count: ${discoverableCategories.length}`}
  >
    {
      discoverableCategories.map((category) => (
        <li class="store-category-signal__item">
          <a
            class="store-category-signal__link"
            data-store-category-link
            data-store-category-active={category.id === activeCategoryId ? '' : undefined}
            href={createProjectRelativeUrl(category.path)}
            aria-current={category.id === activeCategoryId ? 'page' : undefined}
          >
            {category.label}
          </a>
        </li>
      ))
    }
  </ul>
</nav>
