---
import InternalPageHero from '@/components/InternalPageHero.astro';
import StoreItemCard from '@/components/cards/StoreItemCard.astro';
import SiteLayout from '@/layouts/SiteLayout.astro';
import { createProjectRelativeUrl } from '@/config/site';
import type { StoreCatalogCategory } from '@/lib/store-categories';
import {
  createStoreDistroGroupHeadingId,
  groupStoreDistroCollectionEntries,
  selectStoreCollectionEntries,
  type StoreCollectionEntry,
} from '@/lib/store-collection';

import StoreCategoryNavigation from './StoreCategoryNavigation.astro';

interface Props {
  category: StoreCatalogCategory;
  entries: StoreCollectionEntry[];
}

const { category, entries } = Astro.props;
const itemCountLabel = `${entries.length} ${entries.length === 1 ? 'item' : 'items'}`;
const distroEntries = category.id === 'all' ? selectStoreCollectionEntries(entries, 'distro') : [];
const distroGroups = groupStoreDistroCollectionEntries(distroEntries);
const STORE_COVERFLOW_PREVIEW_SIZE = 6;
const STORE_COVERFLOW_INITIAL_POSITIONS = [
  'active',
  'right-near',
  'right-far',
  'back',
  'left-far',
  'left-near',
] as const;
const allCoverflowEligible = category.id === 'all' && entries.length > STORE_COVERFLOW_PREVIEW_SIZE;
const allInitialPositionRatio = entries.length > 0 ? 1 / entries.length : 0;
---

<SiteLayout pageTitle={category.title} pageDescription={category.description}>
  <InternalPageHero sectionLabel="Store" title={category.heading} />

  <StoreCategoryNavigation activeCategoryId={category.id} />

  {
    category.id === 'distro' ? (
      <slot name="distro" />
    ) : (
      <>
        <section class="layout-container pb-6 pt-8" aria-labelledby="store-collection-heading">
          {category.id === 'all' ? (
            <div class="store-orientation-panel store-orientation-panel--all" data-store-orientation="all">
              <div class="store-orientation-panel__primary">
                <p class="store-orientation-panel__eyebrow">Store shelf</p>
                <h2 class="store-orientation-panel__title" id="store-collection-heading">
                  One shelf for label releases, distro finds, and whatever still belongs in the room.
                </h2>
                <p class="store-orientation-panel__total">{itemCountLabel} total</p>
              </div>
              {distroGroups.length > 0 && (
                <nav class="store-format-ledger" aria-label="Browse Distro formats">
                  <p class="store-orientation-panel__eyebrow">Browse Distro formats</p>
                  <ul class="store-format-ledger__list">
                    {distroGroups.map((group) => (
                      <li>
                        <a
                          class="store-format-ledger__link"
                          href={createProjectRelativeUrl(
                            `/store/distro/#${createStoreDistroGroupHeadingId(group.groupName)}`,
                          )}
                        >
                          <span>{group.groupName}</span>
                          <span>{group.entries.length}</span>
                        </a>
                      </li>
                    ))}
                  </ul>
                </nav>
              )}
            </div>
          ) : category.id === 'blackbox-releases' ? (
            <div
              class="store-orientation-panel store-orientation-panel--blackbox"
              data-store-orientation="blackbox-releases"
            >
              <div class="store-orientation-panel__primary">
                <p class="store-orientation-panel__eyebrow">Store shelf</p>
                <h2 class="store-orientation-panel__title" id="store-collection-heading">
                  {category.label}
                </h2>
                <p class="store-orientation-panel__copy">{category.description}</p>
              </div>
              <div class="store-orientation-panel__count">
                <p class="store-orientation-panel__eyebrow">Collection total</p>
                <p class="store-orientation-panel__count-value">{itemCountLabel}</p>
              </div>
            </div>
          ) : (
            <div class="store-orientation-panel store-orientation-panel--generic" data-store-orientation="generic">
              <div class="store-orientation-panel__primary">
                <p class="store-orientation-panel__eyebrow">Store shelf</p>
                <h2 class="store-orientation-panel__title" id="store-collection-heading">
                  {category.label}
                </h2>
                <p class="store-orientation-panel__copy">{category.description}</p>
              </div>
              <div class="store-orientation-panel__count">
                <p class="store-orientation-panel__eyebrow">Collection total</p>
                <p class="store-orientation-panel__count-value">{itemCountLabel}</p>
              </div>
            </div>
          )}
        </section>

        <section
          class:list={['layout-container pb-14', allCoverflowEligible && 'store-coverflow-section']}
          aria-label={`${category.label} Store collection`}
          data-store-coverflow-group={allCoverflowEligible ? '' : undefined}
          data-store-coverflow-mode={allCoverflowEligible ? 'preview' : undefined}
          data-store-coverflow-total={allCoverflowEligible ? entries.length : undefined}
          data-store-coverflow-preview-count={allCoverflowEligible ? STORE_COVERFLOW_PREVIEW_SIZE : undefined}
          data-store-coverflow-remaining-count={allCoverflowEligible ? entries.length - 1 : undefined}
          data-store-coverflow-initial-position-ratio={allCoverflowEligible ? allInitialPositionRatio : undefined}
          style={allCoverflowEligible ? `--store-coverflow-position-ratio: ${allInitialPositionRatio}` : undefined}
        >
          {entries.length > 0 ? (
            <>
              {allCoverflowEligible && (
                <div class="store-coverflow-overview">
                  <div class="store-coverflow-controls" data-store-coverflow-controls>
                    <div class="store-coverflow-depth">
                      <dl class="store-coverflow-stats">
                        <div class="store-coverflow-stat">
                          <dt>On this shelf</dt>
                          <dd>{entries.length}</dd>
                        </div>
                        <div class="store-coverflow-stat" data-store-coverflow-current>
                          <dt>Now viewing</dt>
                          <dd data-store-coverflow-current-value data-store-coverflow-initial-value="1">
                            1
                          </dd>
                        </div>
                        <div class="store-coverflow-stat" data-store-coverflow-remaining>
                          <dt>More</dt>
                          <dd
                            data-store-coverflow-remaining-value
                            data-store-coverflow-initial-value={entries.length - 1}
                          >
                            {entries.length - 1}
                          </dd>
                        </div>
                      </dl>
                      <div class="store-coverflow-rail" aria-hidden="true">
                        <span class="store-coverflow-rail__track" />
                        <span class="store-coverflow-rail__fill" data-store-coverflow-disclosure-rail />
                      </div>
                      <p
                        class="store-coverflow-summary"
                        data-store-coverflow-summary
                        data-store-coverflow-initial-label={`You're viewing 1 of ${entries.length}.`}
                      >
                        You're viewing 1 of {entries.length}.
                      </p>
                    </div>
                    <div class="store-coverflow-actions">
                      <button type="button" aria-controls="all-store-catalog" data-store-coverflow-previous>
                        Previous
                      </button>
                      <button type="button" aria-controls="all-store-catalog" data-store-coverflow-next>
                        Next
                      </button>
                      <button
                        class="store-coverflow-actions__toggle"
                        type="button"
                        aria-controls="all-store-catalog"
                        aria-expanded="false"
                        data-store-coverflow-toggle
                        data-store-coverflow-view-all-label={`View all ${entries.length}`}
                      >
                        View all {entries.length}
                      </button>
                    </div>
                  </div>
                </div>
              )}
              {allCoverflowEligible && (
                <p
                  class="store-coverflow-status"
                  role="status"
                  aria-live="polite"
                  aria-atomic="true"
                  data-store-coverflow-status
                  data-store-coverflow-initial-label={`${entries[0]!.storeItem.title} — ${entries[0]!.storeItem.subtitle}`}
                >
                  {entries[0]!.storeItem.title} — {entries[0]!.storeItem.subtitle}
                </p>
              )}
              <div class="store-coverflow-shell">
                {allCoverflowEligible && (
                  <span class="store-coverflow-reveal" data-store-coverflow-reveal-mask aria-hidden="true" />
                )}
                <div
                  id={allCoverflowEligible ? 'all-store-catalog' : undefined}
                  class="store-catalog-chunks"
                  data-store-coverflow-stage={allCoverflowEligible ? '' : undefined}
                >
                  {entries.map((entry, itemIndex) => (
                    <StoreItemCard
                      entry={entry}
                      imageLoading={itemIndex < 3 ? 'eager' : 'lazy'}
                      coverflowPreview={allCoverflowEligible}
                      coverflowPosition={
                        allCoverflowEligible ? STORE_COVERFLOW_INITIAL_POSITIONS[itemIndex] : undefined
                      }
                    />
                  ))}
                </div>
              </div>
            </>
          ) : (
            <p class="border border-border/70 px-6 py-8 text-sm text-muted-foreground" role="status">
              No merch currently available.
            </p>
          )}
        </section>
      </>
    )
  }
</SiteLayout>
