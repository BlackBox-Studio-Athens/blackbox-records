---
import InternalPageHero from '@/components/InternalPageHero.astro';
import StoreItemCard from '@/components/cards/StoreItemCard.astro';
import SiteLayout from '@/layouts/SiteLayout.astro';
import type { StoreCatalogCategory } from '@/lib/store-categories';
import type { StoreCollectionEntry } from '@/lib/store-collection';

import StoreCategoryNavigation from './StoreCategoryNavigation.astro';

interface Props {
  category: StoreCatalogCategory;
  entries: StoreCollectionEntry[];
}

const { category, entries } = Astro.props;
const itemCountLabel = `${entries.length} ${entries.length === 1 ? 'item' : 'items'}`;
---

<SiteLayout pageTitle={category.title} pageDescription={category.description}>
  <InternalPageHero sectionLabel="Store" title={category.heading} />

  <StoreCategoryNavigation activeCategoryId={category.id} />

  {
    category.id === 'distro' ? (
      <slot name="distro" />
    ) : (
      <>
        <section class="layout-container pb-6 pt-8" aria-labelledby="store-collection-heading">
          <div class="grid gap-6 border border-border/70 bg-card/35 p-6 md:grid-cols-[minmax(0,1.2fr)_minmax(18rem,0.8fr)] md:p-8">
            <div class="space-y-5">
              <p class="text-[11px] uppercase tracking-[0.22em] text-muted-foreground">Store shelf</p>
              <h2 class="brand-section-title max-w-3xl text-foreground" id="store-collection-heading">
                {category.id === 'all'
                  ? 'One shelf for label releases, distro finds, and whatever still belongs in the room.'
                  : category.description}
              </h2>
            </div>
            <div class="border-t border-border/60 pt-4 md:border-t-0 md:border-l md:pl-6 md:pt-0">
              <p class="text-[10px] uppercase tracking-[0.18em] text-muted-foreground">Collection</p>
              <p class="mt-3 text-sm leading-relaxed text-muted-foreground">{itemCountLabel}</p>
            </div>
          </div>
        </section>

        <section class="layout-container pb-14" aria-label={`${category.label} Store collection`}>
          {entries.length > 0 ? (
            <div class="store-catalog-chunks">
              {entries.map((entry, itemIndex) => (
                <StoreItemCard entry={entry} imageLoading={itemIndex < 3 ? 'eager' : 'lazy'} />
              ))}
            </div>
          ) : (
            <p class="border border-border/70 px-6 py-8 text-sm text-muted-foreground" role="status">
              No merch currently available.
            </p>
          )}
        </section>
      </>
    )
  }
</SiteLayout>
