---
import DistroCard from '@/components/cards/DistroCard.astro';
import { buttonVariants } from '@/components/ui/button';
import { getDistroPageContent } from '@/lib/site-data';
import {
  createStoreDistroGroupHeadingId,
  groupStoreDistroCollectionEntries,
  type StoreCollectionEntry,
} from '@/lib/store-collection';
import { cn } from '@/lib/utils';

interface Props {
  entries: StoreCollectionEntry[];
}

const { entries } = Astro.props;
const distroPageContent = await getDistroPageContent();
const STORE_COVERFLOW_PREVIEW_SIZE = 6;
const STORE_COVERFLOW_INITIAL_POSITIONS = [
  'active',
  'right-near',
  'right-far',
  'back',
  'left-far',
  'left-near',
] as const;
const groupedDistroEntries = groupStoreDistroCollectionEntries(entries);
const groupedDistroChunks = groupedDistroEntries.map((group) => {
  const totalCount = group.entries.length;
  const positionedCount = Math.min(STORE_COVERFLOW_PREVIEW_SIZE, totalCount);
  const initialCurrentPosition = 1;
  const initialRemainingCount = totalCount - initialCurrentPosition;
  const initialPositionRatio = initialCurrentPosition / totalCount;

  return {
    ...group,
    totalCount,
    positionedCount,
    initialCurrentPosition,
    initialRemainingCount,
    initialPositionRatio,
    coverflowEligible: totalCount > STORE_COVERFLOW_PREVIEW_SIZE,
    headingId: createStoreDistroGroupHeadingId(group.groupName),
    chunks: group.entries.reduce<(typeof group.entries)[]>((chunks, entry, index) => {
      if (index % STORE_COVERFLOW_PREVIEW_SIZE === 0) chunks.push([]);
      chunks.at(-1)!.push(entry);
      return chunks;
    }, []),
  };
});
const eagerDistroStoreItemSlugs = new Set(entries.slice(0, 3).map((entry) => entry.storeItem.slug));
const itemCountLabel = `${entries.length} ${entries.length === 1 ? 'item' : 'items'}`;
---

<section id="distro-page-top" class="layout-container distro-page-intro" aria-labelledby="distro-collection-heading">
  <div class="store-orientation-panel store-orientation-panel--distro" data-store-orientation="distro">
    <div class="store-orientation-panel__primary">
      <p class="store-orientation-panel__eyebrow">Store shelf</p>
      <h2 class="store-orientation-panel__title" id="distro-collection-heading">{distroPageContent.hero.title}</h2>
      <p class="store-orientation-panel__copy">{distroPageContent.hero.intro}</p>
    </div>
    <div class="store-orientation-panel__distro-tools">
      <div class="store-orientation-panel__distro-count">
        <p class="store-orientation-panel__eyebrow">Collection total</p>
        <p class="store-orientation-panel__count-value">{itemCountLabel}</p>
      </div>
      <div class="distro-page-search" data-distro-search></div>
    </div>
  </div>
</section>

<nav class="distro-format-navigation" aria-labelledby="distro-format-navigation-heading" data-distro-format-navigation>
  <div class="layout-container distro-format-navigation__inner">
    <div class="distro-format-navigation__desktop">
      <h2 id="distro-format-navigation-heading" class="distro-format-navigation__heading">Browse formats</h2>
      <div class="distro-format-navigation__links">
        {
          groupedDistroChunks.map((group) => (
            <a
              href={`#${group.headingId}`}
              data-scroll-to-target={group.headingId}
              class={cn(
                buttonVariants({ variant: 'outline', size: 'sm' }),
                'distro-format-navigation__link h-auto rounded-none border-[#3a3a3a] bg-transparent px-3 py-2 text-[11px] tracking-[0.14em] uppercase shadow-none hover:border-[#666666] hover:bg-[#1a1a1a]',
              )}
            >
              <span class="distro-format-navigation__link-label">{group.groupName}</span>
              <span class="text-muted-foreground">({group.entries.length})</span>
            </a>
          ))
        }
      </div>
    </div>
    <details class="distro-format-navigation__mobile" data-distro-format-disclosure>
      <summary class="distro-format-navigation__summary">
        <span>Browse formats</span>
        <span class="distro-format-navigation__count">{groupedDistroChunks.length}</span>
        <span class="distro-format-navigation__indicator" aria-hidden="true">▾</span>
      </summary>
      <div class="distro-format-navigation__panel">
        {
          groupedDistroChunks.map((group) => (
            <a
              href={`#${group.headingId}`}
              data-scroll-to-target={group.headingId}
              class="distro-format-navigation__link h-auto rounded-none border border-[#3a3a3a] bg-transparent px-3 py-2 text-[11px] tracking-[0.14em] text-foreground uppercase shadow-none outline-none hover:border-[#666666] hover:bg-[#1a1a1a] focus-visible:ring-[3px] focus-visible:ring-ring/50"
            >
              <span class="distro-format-navigation__link-label">{group.groupName}</span>
              <span class="text-muted-foreground">({group.entries.length})</span>
            </a>
          ))
        }
      </div>
    </details>
    <a
      href="#distro-page-top"
      data-scroll-to-target="distro-page-top"
      aria-label="Back to Distro page top"
      class={cn(
        buttonVariants({ variant: 'outline', size: 'sm' }),
        'distro-format-navigation__top h-auto rounded-none border-[#666666] bg-[#f5f5f5] px-3 py-2 text-[11px] tracking-[0.14em] text-[#0d0d0d] uppercase shadow-none hover:border-white hover:bg-white',
      )}
    >
      Top <span aria-hidden="true">↑</span>
    </a>
  </div>
</nav>

<section
  id="distro-search-results"
  class="layout-container distro-page-groups"
  aria-label="Distro"
  data-distro-search-root
>
  {
    groupedDistroChunks.map((group) => (
      <section
        class:list={['distro-group-section', group.coverflowEligible && 'distro-group-section--coverflow']}
        aria-labelledby={group.headingId}
        data-distro-search-group
        data-store-coverflow-group={group.coverflowEligible ? '' : undefined}
        data-store-coverflow-mode={group.coverflowEligible ? 'preview' : undefined}
        data-store-coverflow-total={group.coverflowEligible ? group.totalCount : undefined}
        data-store-coverflow-preview-count={group.coverflowEligible ? group.positionedCount : undefined}
        data-store-coverflow-remaining-count={group.coverflowEligible ? group.initialRemainingCount : undefined}
        data-store-coverflow-initial-position-ratio={group.coverflowEligible ? group.initialPositionRatio : undefined}
        style={group.coverflowEligible ? `--store-coverflow-position-ratio: ${group.initialPositionRatio}` : undefined}
      >
        <div
          class:list={[
            'distro-group-section__overview',
            group.coverflowEligible && 'distro-group-section__overview--coverflow',
          ]}
        >
          <div class="distro-group-section__header">
            <h2 class="distro-group-section__title" id={group.headingId}>
              {group.groupName}
            </h2>
            <p class="distro-group-section__copy">{distroPageContent.group_intros[group.introGroupName]}</p>
          </div>
          {group.coverflowEligible && (
            <div class="store-coverflow-controls" data-store-coverflow-controls>
              <div class="store-coverflow-depth">
                <dl class="store-coverflow-stats">
                  <div class="store-coverflow-stat">
                    <dt>In this format</dt>
                    <dd>{group.totalCount}</dd>
                  </div>
                  <div class="store-coverflow-stat" data-store-coverflow-current>
                    <dt>Now viewing</dt>
                    <dd data-store-coverflow-current-value data-store-coverflow-initial-value="1">
                      {group.initialCurrentPosition}
                    </dd>
                  </div>
                  <div class="store-coverflow-stat" data-store-coverflow-remaining>
                    <dt>More</dt>
                    <dd
                      data-store-coverflow-remaining-value
                      data-store-coverflow-initial-value={group.initialRemainingCount}
                    >
                      {group.initialRemainingCount}
                    </dd>
                  </div>
                </dl>
                <div class="store-coverflow-rail" aria-hidden="true">
                  <span class="store-coverflow-rail__track" />
                  <span class="store-coverflow-rail__fill" data-store-coverflow-disclosure-rail />
                </div>
                <p
                  class="store-coverflow-summary"
                  data-store-coverflow-summary
                  data-store-coverflow-initial-label={`You're viewing ${group.initialCurrentPosition} of ${group.totalCount}.`}
                >
                  You're viewing {group.initialCurrentPosition} of {group.totalCount}.
                </p>
              </div>
              <div class="store-coverflow-actions">
                <button type="button" aria-controls={`${group.headingId}-catalog`} data-store-coverflow-previous>
                  Previous
                </button>
                <button type="button" aria-controls={`${group.headingId}-catalog`} data-store-coverflow-next>
                  Next
                </button>
                <button
                  class="store-coverflow-actions__toggle"
                  type="button"
                  aria-controls={`${group.headingId}-catalog`}
                  aria-expanded="false"
                  data-store-coverflow-toggle
                  data-store-coverflow-view-all-label={`View all ${group.totalCount}`}
                >
                  View all {group.totalCount}
                </button>
              </div>
            </div>
          )}
        </div>
        {group.coverflowEligible && (
          <p
            class="store-coverflow-status"
            role="status"
            aria-live="polite"
            aria-atomic="true"
            data-store-coverflow-status
            data-store-coverflow-initial-label={`${group.entries[0]!.storeItem.title} — ${group.entries[0]!.storeItem.subtitle}`}
          >
            {group.entries[0]!.storeItem.title} — {group.entries[0]!.storeItem.subtitle}
          </p>
        )}
        <div class="store-coverflow-shell">
          {group.coverflowEligible && (
            <span class="store-coverflow-reveal" data-store-coverflow-reveal-mask aria-hidden="true" />
          )}
          <div
            id={group.coverflowEligible ? `${group.headingId}-catalog` : undefined}
            class="distro-group-chunks"
            data-store-coverflow-stage={group.coverflowEligible ? '' : undefined}
          >
            {group.chunks.map((chunk, chunkIndex) => (
              <div class="distro-group-grid distro-group-chunk" data-distro-search-chunk>
                {chunk.map((entry, itemIndex) => (
                  <DistroCard
                    entry={entry}
                    imageLoading={eagerDistroStoreItemSlugs.has(entry.storeItem.slug) ? 'eager' : 'lazy'}
                    coverflowPreview={group.coverflowEligible}
                    coverflowPosition={
                      group.coverflowEligible
                        ? STORE_COVERFLOW_INITIAL_POSITIONS[chunkIndex * STORE_COVERFLOW_PREVIEW_SIZE + itemIndex]
                        : undefined
                    }
                  />
                ))}
              </div>
            ))}
          </div>
        </div>
      </section>
    ))
  }
</section>
