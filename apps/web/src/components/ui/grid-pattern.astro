---
const { class: className, squareSize = 34 } = Astro.props;

const patternId = `grid-pattern-${crypto.randomUUID()}`;
---

<div class:list={['grid-pattern', className]} aria-hidden="true">
  <svg class="grid-pattern__svg" xmlns="http://www.w3.org/2000/svg">
    <defs>
      <pattern id={patternId} width={squareSize} height={squareSize} patternUnits="userSpaceOnUse">
        <path d={`M ${squareSize} 0 L 0 0 0 ${squareSize}`} fill="none" stroke="currentColor" stroke-width="0.65"
        ></path>
      </pattern>
      <linearGradient id={`${patternId}-fade`} x1="0" y1="0" x2="0" y2="1">
        <stop offset="0%" stop-color="rgba(255,255,255,0.9)"></stop>
        <stop offset="58%" stop-color="rgba(255,255,255,0.28)"></stop>
        <stop offset="100%" stop-color="rgba(255,255,255,0)"></stop>
      </linearGradient>
      <mask id={`${patternId}-mask`}>
        <rect width="100%" height="100%" fill={`url(#${patternId}-fade)`}></rect>
      </mask>
    </defs>
    <rect width="100%" height="100%" fill={`url(#${patternId})`} mask={`url(#${patternId}-mask)`}></rect>
  </svg>
</div>
