---
import { cn } from '@/lib/utils';

type EmbeddedPlayerData = {
  hasProvider: boolean;
  title: string;
  bandcampEmbedUrl: string;
  tidalEmbedUrl: string;
};

interface Props {
  embeddedPlayerData: EmbeddedPlayerData;
  as?: 'button' | 'span';
  class?: string;
  includePlayerData?: boolean;
  includeCardAttribute?: boolean;
  label?: string;
  tone?: 'neutral' | 'accent';
  variant?: 'compact' | 'standalone';
}

const {
  embeddedPlayerData,
  as = 'button',
  class: className,
  includePlayerData = true,
  includeCardAttribute = false,
  label = 'Listen',
  tone = 'neutral',
  variant = 'compact',
} = Astro.props as Props;

const Tag = as;
const elementAttributes = as === 'button' ? { type: 'button' as const } : {};
const playerDataAttributes =
  includePlayerData && embeddedPlayerData.hasProvider
    ? {
        'data-music-streaming-service-embedded-player-title': embeddedPlayerData.title,
        'data-music-streaming-service-embedded-player-bandcamp-embed-url':
          embeddedPlayerData.bandcampEmbedUrl || undefined,
        'data-music-streaming-service-embedded-player-tidal-embed-url': embeddedPlayerData.tidalEmbedUrl || undefined,
      }
    : {};
---

{
  embeddedPlayerData.hasProvider && (
    <Tag
      class={cn(
        'music-listen-trigger release-card-listen-trigger inline-flex items-center border transition-[background-color,box-shadow,transform] duration-200',
        `music-listen-trigger--${variant}`,
        `music-listen-trigger--tone-${tone}`,
        className,
      )}
      data-music-listen-trigger-variant={variant}
      data-music-listen-trigger-tone={tone}
      data-music-streaming-service-embedded-player-trigger
      data-music-streaming-service-embedded-player-card={includeCardAttribute ? true : undefined}
      {...elementAttributes}
      {...playerDataAttributes}
    >
      <span class="music-listen-trigger__indicator release-card-listen-trigger__indicator" aria-hidden="true" />
      {label}
    </Tag>
  )
}
