---
import { createProjectRelativeUrl } from '@/config/site';
import { getHeaderNavigationItems } from '@/lib/site-data';
import HeaderBrand from '@/components/header/HeaderBrand.astro';
import HeaderDesktopNav from '@/components/header/HeaderDesktopNav.astro';
import HeaderShell from '@/components/header/HeaderShell.astro';
import { Menu } from 'lucide-react';

interface Props {
  pathname: string;
}

const { pathname } = Astro.props;
const headerNavigationItems = await getHeaderNavigationItems();
---

<HeaderShell>
  <div class="header-brand-group">
    <HeaderBrand href={createProjectRelativeUrl('/')} />
    {
      import.meta.env.SHOW_REVIEW_SITE_MARKER === 'true' && (
        <span class="header-review-site-marker" aria-label="Test site. Test payments only.">
          <span class="header-review-site-marker-label" aria-hidden="true">
            TEST SITE
          </span>
          <span aria-hidden="true">Test payments only</span>
        </span>
      )
    }
  </div>
  <HeaderDesktopNav items={headerNavigationItems} pathname={pathname} />

  <div class="flex items-center gap-1">
    <div data-store-cart-header-root></div>
    <button
      type="button"
      class="inline-flex size-11 items-center justify-center rounded-none border-0 bg-transparent p-0 text-foreground transition-colors hover:bg-transparent hover:text-foreground focus-visible:outline-none focus-visible:ring-0 focus-visible:ring-offset-0 lg:hidden"
      aria-label="Toggle navigation"
      data-app-shell-mobile-navigation-trigger
    >
      <Menu className="size-4" />
    </button>
  </div>
</HeaderShell>
