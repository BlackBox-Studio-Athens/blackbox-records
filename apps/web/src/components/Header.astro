---
import { createProjectRelativeUrl } from '@/config/site';
import { getHeaderNavigationItems } from '@/lib/site-data';
import HeaderBrand from '@/components/header/HeaderBrand.astro';
import HeaderDesktopNav from '@/components/header/HeaderDesktopNav.astro';
import HeaderShell from '@/components/header/HeaderShell.astro';
import { Menu } from 'lucide-react';

interface Props {
  pathname: string;
}

const { pathname } = Astro.props;
const headerNavigationItems = await getHeaderNavigationItems();
---

<HeaderShell>
  <HeaderBrand href={createProjectRelativeUrl('/')} />
  <HeaderDesktopNav items={headerNavigationItems} pathname={pathname} />

  <div class="md:hidden">
    <button
      type="button"
      class="inline-flex size-11 items-center justify-center rounded-none border-0 bg-transparent p-0 text-foreground transition-colors hover:bg-transparent hover:text-foreground focus-visible:outline-none focus-visible:ring-0 focus-visible:ring-offset-0"
      aria-label="Toggle navigation"
      data-app-shell-mobile-navigation-trigger
    >
      <Menu className="size-4" />
    </button>
  </div>
</HeaderShell>
