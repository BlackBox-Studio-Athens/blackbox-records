---
interface Props {
  class?: string;
}

const { class: className } = Astro.props;
---

<header
  class:list={[
    'fixed inset-x-0 top-0 z-[1000] h-[var(--header-height)] border-b border-[#2b2b2b] bg-[#0d0d0d]/90 backdrop-blur-[10px]',
    className,
  ]}
>
  <div class="mx-auto flex h-full w-full max-w-[1240px] items-center justify-between gap-4 px-[var(--header-padding-x-mobile)] md:gap-6 md:px-[var(--header-padding-x-desktop)]">
    <slot />
  </div>
</header>
