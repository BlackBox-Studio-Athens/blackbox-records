---
import type { ImageMetadata } from 'astro';
import { Image } from 'astro:assets';
interface Props {
  tagline: string;
  image: ImageMetadata;
  imageAlt: string;
  scrollIndicatorText?: string;
}

const { tagline, image, imageAlt, scrollIndicatorText = 'Scroll' } = Astro.props;
---

<section class="homepage-hero-section border-b border-border/70" id="homepage-hero-section">
  <div class="homepage-hero-section__media-layer" aria-hidden="true">
    <Image
      src={image}
      alt={imageAlt}
      class="homepage-hero-section__media-image"
      priority
      widths={[900, 1400, 2000]}
      sizes="100vw"
    />
  </div>
  <div class="homepage-hero-section__shade-layer" aria-hidden="true"></div>
  <div class="homepage-hero-section__grain-layer" aria-hidden="true"></div>

  <div class="homepage-hero-section__content-block page-content-width-constrained-container">
    <h1 class="sr-only">BlackBox Records</h1>
    <p class="homepage-hero-section__tagline-text">{tagline}</p>
  </div>

  <div class="homepage-hero-section__scroll-indicator" aria-hidden="true">
    <span>{scrollIndicatorText}</span>
    <div class="homepage-hero-section__scroll-indicator-line">
      <span></span>
    </div>
  </div>
</section>
