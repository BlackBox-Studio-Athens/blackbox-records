---
import { Image } from 'astro:assets';
import type { CollectionEntry } from 'astro:content';
import { Card, CardContent } from '@/components/ui/card';
import { createStoreItemFromDistroEntry } from '@/lib/catalog-data';
import { cn } from '@/lib/utils';
import { formatMonthYear } from '@/utils/content';

interface Props {
  coverflowPosition?: 'active' | 'back' | 'left-far' | 'left-near' | 'right-far' | 'right-near' | undefined;
  coverflowPreview?: boolean;
  item: CollectionEntry<'distro'>;
  imageLoading?: 'eager' | 'lazy';
  variant?: 'home' | 'page';
}

const { coverflowPosition, coverflowPreview = false, item, imageLoading = 'lazy', variant = 'page' } = Astro.props;
const storeItem = createStoreItemFromDistroEntry(item);
const isHomeVariant = variant === 'home';
const distroCardImageWidths = [320, 480, 640, 800, 960];
const metadataItems = [
  item.data.eyebrow || null,
  item.data.format || item.data.group,
  item.data.release_date ? formatMonthYear(item.data.release_date) : null,
].filter(Boolean);
const distroSearchText = [item.data.title, item.data.artist_or_label, item.data.group, item.data.format]
  .filter(Boolean)
  .join(' ');
---

<a
  class:list={['group block h-full distro-card', isHomeVariant ? 'distro-card--home' : 'distro-card--page']}
  href={storeItem.storePath}
  aria-label={isHomeVariant ? undefined : `${item.data.title} — ${item.data.artist_or_label}`}
  data-astro-prefetch
  data-distro-coverflow-card={coverflowPreview ? '' : undefined}
  data-distro-coverflow-initial-position={coverflowPosition}
  data-distro-coverflow-position={coverflowPosition}
  data-distro-search-item={isHomeVariant ? undefined : ''}
  data-distro-search-text={isHomeVariant ? undefined : distroSearchText}
>
  <Card className="distro-card__surface rounded-none border-[#2b2b2b] bg-[#141414] shadow-none">
    <div class="distro-card__image-frame">
      <Image
        src={item.data.image}
        alt={item.data.image_alt}
        class="distro-card__image"
        widths={distroCardImageWidths}
        sizes={isHomeVariant
          ? '(min-width: 1280px) 24vw, (min-width: 768px) 33vw, 100vw'
          : '(min-width: 1280px) 22vw, (min-width: 768px) 45vw, 100vw'}
        loading={imageLoading}
      />
    </div>
    <CardContent className={cn('distro-card__content', isHomeVariant ? 'space-y-2 p-4' : 'space-y-3 p-5')}>
      <div class="space-y-2">
        {
          metadataItems.length > 0 && (
            <div class="distro-card__metadata-row">
              {metadataItems.map((metadataItem) => (
                <span>{metadataItem}</span>
              ))}
            </div>
          )
        }
        <h3 class="distro-card__title">{item.data.title}</h3>
        <p class="text-[12px] uppercase tracking-[0.14em] text-muted-foreground">{item.data.artist_or_label}</p>
      </div>
      {!isHomeVariant && <p class="distro-card__summary">{item.data.summary}</p>}
      {
        !isHomeVariant && (
          <span class="inline-flex items-center gap-2 text-[11px] uppercase tracking-[0.16em] text-foreground/88">
            View in Store <span aria-hidden="true">→</span>
          </span>
        )
      }
    </CardContent>
  </Card>
</a>
