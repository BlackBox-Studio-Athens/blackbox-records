---
import { Image } from 'astro:assets';
import { Card, CardContent } from '@/components/ui/card';
import type { StoreCollectionEntry } from '@/lib/store-collection';

interface Props {
  entry: StoreCollectionEntry;
}

const { entry } = Astro.props;
const { storeItem, primaryAvailability } = entry;
const priceLabel = primaryAvailability?.price.display || 'Price soon';
const availabilityLabel = primaryAvailability?.availability.label || 'Unavailable';
const metadataLabel = storeItem.metadata.join(' · ');
const collectionLabel = storeItem.eyebrow || (storeItem.sourceKind === 'release' ? 'Release' : 'Distro');
---

<a class="group block h-full" href={storeItem.storePath} data-astro-prefetch>
  <Card className="h-full rounded-none border-[#2b2b2b] bg-[#121212] shadow-none transition-colors duration-300 group-hover:border-[#4a4a4a]">
    <div class="relative aspect-[4/5] overflow-hidden border-b border-[#2b2b2b] bg-[#0d0d0d]">
      <Image
        src={storeItem.image}
        alt={storeItem.imageAlt}
        class="h-full w-full object-cover transition-transform duration-500 group-hover:scale-[1.03]"
        sizes="(min-width: 1280px) 24vw, (min-width: 768px) 33vw, 100vw"
      />
      <div class="absolute inset-0 bg-gradient-to-t from-black via-black/18 to-transparent"></div>
      <div class="absolute inset-x-0 bottom-0 flex items-center justify-between gap-3 px-4 py-4">
        <div class="flex flex-wrap items-center gap-2 text-[10px] uppercase tracking-[0.18em] text-white/78">
          <span>{collectionLabel}</span>
        </div>
        <span
          class:list={[
            'inline-flex items-center border px-2 py-1 text-[10px] uppercase tracking-[0.18em]',
            primaryAvailability?.canBuy
              ? 'border-white/25 bg-black/35 text-white/82'
              : 'border-white/15 bg-black/45 text-white/55',
          ]}
        >
          {availabilityLabel}
        </span>
      </div>
    </div>
    <CardContent className="flex h-[calc(100%-theme(spacing.0))] flex-col gap-4 p-5">
      <div class="space-y-2">
        {metadataLabel && <p class="text-[11px] uppercase tracking-[0.18em] text-muted-foreground">{metadataLabel}</p>}
        <h2 class="font-display text-3xl tracking-[0.08em] uppercase text-foreground">{storeItem.title}</h2>
        <p class="text-[12px] uppercase tracking-[0.16em] text-muted-foreground">{storeItem.subtitle}</p>
      </div>

      {storeItem.summary && <p class="text-sm leading-relaxed text-muted-foreground">{storeItem.summary}</p>}

      <div class="mt-auto flex items-end justify-between gap-4 border-t border-border/50 pt-4">
        <div class="space-y-1">
          <p class="text-[10px] uppercase tracking-[0.18em] text-muted-foreground">Price</p>
          <p class="font-display text-2xl tracking-[0.08em] uppercase text-foreground">{priceLabel}</p>
        </div>
        <span class="inline-flex items-center gap-2 text-[11px] uppercase tracking-[0.18em] text-foreground/88">
          View Item <span aria-hidden="true">→</span>
        </span>
      </div>
    </CardContent>
  </Card>
</a>
