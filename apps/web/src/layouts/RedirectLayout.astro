---
import '@/styles/global.css';

import { createProjectRelativeUrl, siteBrandAssets, siteConfig } from '@/config/site';

interface Props {
  pageTitle: string;
  pageDescription: string;
  preserveFragment?: boolean;
  redirectUrl: string;
}

const { pageTitle, pageDescription, preserveFragment = false, redirectUrl } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{`${pageTitle} | ${siteConfig.title}`}</title>
    <meta name="description" content={pageDescription} />
    <link rel="icon" href={createProjectRelativeUrl(siteBrandAssets.faviconSvg)} type="image/svg+xml" sizes="any" />
    <link rel="icon" href={createProjectRelativeUrl(siteBrandAssets.faviconPng96)} type="image/png" sizes="96x96" />
    <link rel="icon" href={createProjectRelativeUrl(siteBrandAssets.faviconIco)} sizes="any" />
    <meta content={`0; url=${redirectUrl}`} http-equiv="refresh" />
    <link rel="canonical" href={redirectUrl} />
    <script is:inline data-preserve-fragment={preserveFragment ? 'true' : undefined} data-redirect-url={redirectUrl}>
      const currentScriptElement = document.currentScript;
      const redirectTarget = currentScriptElement?.dataset.redirectUrl;
      if (window.location && redirectTarget) {
        const target =
          currentScriptElement?.dataset.preserveFragment === 'true'
            ? `${redirectTarget}${window.location.hash}`
            : redirectTarget;
        window.location.replace(target);
      }
    </script>
  </head>
  <body class="grid min-h-screen place-items-center bg-background px-6 text-foreground">
    <main class="w-full max-w-xl rounded-xl border border-border bg-card p-8 text-center shadow-2xl shadow-black/35">
      <slot />
    </main>
  </body>
</html>
