---
import '@/styles/global.css';

import { createProjectRelativeUrl, siteConfig } from '@/config/site';

interface Props {
  pageTitle: string;
  pageDescription: string;
}

const { pageTitle, pageDescription } = Astro.props;
const htmlTitle = `${pageTitle} | ${siteConfig.title}`;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{htmlTitle}</title>
    <meta name="description" content={pageDescription} />
    <meta name="robots" content="noindex, nofollow" />
    <link rel="icon" href={createProjectRelativeUrl('/assets/images/brand/logo.png')} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin="anonymous" />
    <link
      href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Geist+Mono:wght@400;500&family=Inter:wght@300;400;500;600&display=swap"
      rel="stylesheet"
    />
  </head>
  <body class="min-h-screen overflow-x-clip bg-background text-foreground">
    <a class="accessibility-skip-to-content-link" href="#main">Skip to stock operations</a>
    <main id="main" tabindex="-1">
      <slot />
    </main>
  </body>
</html>
