---
import NewsCard from '@/components/cards/NewsCard.astro';
import InternalPageHero from '@/components/InternalPageHero.astro';
import SiteLayout from '@/layouts/SiteLayout.astro';
import { listNewsArticles } from '@/lib/catalog-data';

const newsArticles = await listNewsArticles();
---

<SiteLayout pageTitle="News" pageDescription="News updates.">
  <InternalPageHero sectionLabel="Updates" title="News" />
  <section class="layout-container">
    <div class="grid gap-5 md:grid-cols-2 xl:grid-cols-3">
        {newsArticles.map((newsArticle) => <NewsCard item={newsArticle} />)}
    </div>
  </section>
</SiteLayout>
