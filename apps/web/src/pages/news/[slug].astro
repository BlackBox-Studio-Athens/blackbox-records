---
import NewsDetailContent from '@/components/detail/NewsDetailContent.astro';
import SiteLayout from '@/layouts/SiteLayout.astro';
import { createNewsDetailStaticPaths, type NewsArticleEntry } from '@/lib/catalog-data';

export async function getStaticPaths() {
  return createNewsDetailStaticPaths();
}

interface Props {
  item: NewsArticleEntry;
}

const { item } = Astro.props;
---

<SiteLayout
  pageTitle={item.data.title}
  pageDescription={item.data.summary}
  image={item.data.image}
  imageAlt={item.data.image_alt || item.data.title}
  layoutType="news"
  pageDate={item.data.date}
>
  <NewsDetailContent item={item} />
</SiteLayout>
