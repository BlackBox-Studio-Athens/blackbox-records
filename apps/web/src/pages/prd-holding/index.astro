---
import { Image } from 'astro:assets';

import { createProjectRelativeUrl, siteBrandAssets } from '@/config/site';
import { getContentSection, getHomeContent, getServicesContent, getSocialItems } from '@/lib/site-data';

const pageTitle = 'BlackBox Records | Site Coming Online';
const pageDescription = 'BlackBox Records is active. The full site is coming online soon.';
const pageUrl = 'https://blackboxrecordsathens.com/';
const logoUrl = createProjectRelativeUrl(siteBrandAssets.badgeLogo);
const socialImageUrl = new URL(siteBrandAssets.badgeLogo, pageUrl).toString();
const veneerCssUrl = createProjectRelativeUrl('/assets/fonts/brand/veneer.css');
const veneerFontUrl = createProjectRelativeUrl('/assets/fonts/brand/veneer_regular.woff2');

const [homeContent, servicesContent, socialItems] = await Promise.all([
  getHomeContent(),
  getServicesContent(),
  getSocialItems(),
]);
const inquiryEmail = getContentSection(servicesContent.sections, 'inquiry')?.email.trim();
const instagramUrl = socialItems.find((item) => {
  if (item.id !== 'instagram' || !item.url || item.url === '#') return false;

  try {
    return new URL(item.url).protocol === 'https:';
  } catch {
    return false;
  }
})?.url;

if (!instagramUrl) {
  throw new Error('PRD Holding Page requires a valid HTTPS Instagram URL in the socials collection.');
}

if (!inquiryEmail || inquiryEmail === '#' || !/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(inquiryEmail)) {
  throw new Error('PRD Holding Page requires a valid inquiry email in the services collection.');
}
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{pageTitle}</title>
    <meta name="description" content={pageDescription} />
    <meta name="robots" content="noindex, nofollow" />
    <meta name="theme-color" content="#0d0d0d" />
    <link rel="canonical" href={pageUrl} />
    <meta property="og:site_name" content="BlackBox Records" />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={pageDescription} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={pageUrl} />
    <meta property="og:image" content={socialImageUrl} />
    <meta property="og:image:alt" content="BlackBox Records logo" />
    <meta property="og:locale" content="en_US" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={pageDescription} />
    <meta name="twitter:image" content={socialImageUrl} />
    <meta name="twitter:image:alt" content="BlackBox Records logo" />
    <link rel="icon" href={createProjectRelativeUrl(siteBrandAssets.faviconSvg)} type="image/svg+xml" sizes="any" />
    <link rel="icon" href={createProjectRelativeUrl(siteBrandAssets.faviconPng96)} type="image/png" sizes="96x96" />
    <link rel="icon" href={createProjectRelativeUrl(siteBrandAssets.faviconIco)} sizes="any" />
    <link rel="preload" href={veneerFontUrl} as="font" type="font/woff2" crossorigin="anonymous" />
    <link rel="stylesheet" href={veneerCssUrl} />
  </head>
  <body>
    <main class="holding-page">
      <section class="holding-page__info" aria-labelledby="holding-title">
        <img class="holding-page__logo" src={logoUrl} alt="BlackBox Records" width="384" height="384" />

        <div class="holding-page__message">
          <p class="holding-page__kicker">BLACKBOX RECORDS · ATHENS</p>
          <h1 id="holding-title">THE SITE IS IN THE PRESS.</h1>
          <p class="holding-page__copy">
            BlackBox Records is active. We’re building a new home for our artists, releases, distro, and services.
          </p>
        </div>

        <div class="holding-page__footer">
          <p class="holding-page__status">FULL SITE COMING ONLINE SOON.</p>
          <nav class="holding-page__actions" aria-label="Contact BlackBox Records">
            <a href={instagramUrl} rel="noreferrer noopener">FOLLOW ON INSTAGRAM <span aria-hidden="true">↗</span></a>
            <a href={`mailto:${inquiryEmail}`}>EMAIL THE LABEL <span aria-hidden="true">→</span></a>
          </nav>
        </div>
      </section>

      <figure class="holding-page__image-field">
        <Image
          src={homeContent.hero.image}
          alt={homeContent.hero.image_alt}
          widths={[640, 960, 1440]}
          sizes="(min-width: 760px) 62vw, 100vw"
          loading="eager"
        />
      </figure>
    </main>
  </body>
</html>

<style>
  :root {
    color-scheme: dark;
    --void: #0d0d0d;
    --ink: #f5f5f5;
    --muted: #b3b3b3;
    --border: #262626;
  }

  * {
    box-sizing: border-box;
  }

  html,
  body {
    min-width: 320px;
    min-height: 100%;
    margin: 0;
    background: var(--void);
    color: var(--ink);
  }

  body {
    font-family: 'Helvetica Neue', Helvetica, Arial, sans-serif;
  }

  .holding-page {
    display: grid;
    min-height: 100vh;
    min-height: 100svh;
    overflow: hidden;
    background: var(--void);
  }

  .holding-page__info {
    position: relative;
    z-index: 1;
    display: grid;
    grid-template-rows: auto 1fr auto;
    min-height: 64svh;
    padding: clamp(1.25rem, 5vw, 4.5rem);
    border-bottom: 1px solid var(--border);
    isolation: isolate;
  }

  .holding-page__info::before {
    position: absolute;
    z-index: -1;
    inset: 0;
    background-image:
      repeating-linear-gradient(0deg, transparent 0 3px, rgb(245 245 245 / 0.014) 3px 4px),
      radial-gradient(circle at 82% 18%, rgb(245 245 245 / 0.035), transparent 32%);
    content: '';
    pointer-events: none;
  }

  .holding-page__info::after {
    position: absolute;
    top: 1.15rem;
    right: -0.6rem;
    width: 1.2rem;
    height: 1.2rem;
    border: 1px solid var(--ink);
    content: '';
    transform: rotate(45deg);
  }

  .holding-page__logo {
    width: clamp(4.5rem, 10vw, 7.5rem);
    height: auto;
  }

  .holding-page__message {
    align-self: center;
    max-width: 34rem;
    padding-block: clamp(2rem, 5vh, 3.5rem);
  }

  .holding-page__kicker,
  .holding-page__status {
    margin: 0;
    color: var(--muted);
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.18em;
    line-height: 1.4;
  }

  h1 {
    max-width: 8ch;
    margin: 0.55rem 0 1.35rem;
    font-family: Veneer, Impact, sans-serif;
    font-size: clamp(3.8rem, 8vw, 6.75rem);
    font-weight: 900;
    letter-spacing: 0.025em;
    line-height: 0.78;
    text-wrap: balance;
  }

  .holding-page__copy {
    max-width: 36ch;
    margin: 0;
    color: var(--muted);
    font-size: clamp(0.95rem, 1.4vw, 1.08rem);
    line-height: 1.65;
  }

  .holding-page__footer {
    display: grid;
    gap: 1rem;
  }

  .holding-page__status {
    padding-top: 1rem;
    border-top: 1px solid var(--border);
    color: var(--ink);
  }

  .holding-page__actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem 1.5rem;
  }

  .holding-page__actions a {
    display: inline-flex;
    min-height: 2.75rem;
    align-items: center;
    gap: 0.45rem;
    color: var(--ink);
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.14em;
    text-underline-offset: 0.32em;
  }

  .holding-page__actions a:hover {
    text-decoration: underline;
  }

  .holding-page__actions a:focus-visible {
    outline: 2px solid var(--ink);
    outline-offset: 0.25rem;
  }

  .holding-page__image-field {
    position: relative;
    min-height: 36svh;
    margin: 0;
    overflow: hidden;
    background: var(--border);
  }

  .holding-page__image-field::after {
    position: absolute;
    inset: 0;
    background: linear-gradient(118deg, rgb(13 13 13 / 0.04), rgb(13 13 13 / 0.3));
    content: '';
    pointer-events: none;
  }

  .holding-page__image-field :global(img) {
    width: 100%;
    height: 100%;
    filter: grayscale(1) contrast(1.14);
    object-fit: cover;
    object-position: center;
  }

  @media (min-width: 760px) {
    .holding-page {
      grid-template-columns: minmax(0, 62fr) minmax(22rem, 38fr);
    }

    .holding-page__info {
      grid-column: 2;
      grid-row: 1;
      min-height: 100svh;
      border-bottom: 0;
      border-left: 1px solid var(--border);
    }

    .holding-page__image-field {
      grid-column: 1;
      grid-row: 1;
      min-height: 100svh;
    }
  }

  @media (prefers-reduced-motion: no-preference) {
    .holding-page__image-field {
      animation: reveal-image 650ms cubic-bezier(0.22, 1, 0.36, 1) both;
    }

    .holding-page__info > * {
      animation: reveal-copy 550ms cubic-bezier(0.22, 1, 0.36, 1) both;
    }

    .holding-page__message {
      animation-delay: 60ms;
    }

    .holding-page__footer {
      animation-delay: 120ms;
    }
  }

  @keyframes reveal-image {
    from {
      opacity: 0;
      transform: scale(1.015);
    }
  }

  @keyframes reveal-copy {
    from {
      opacity: 0;
      transform: translateY(0.65rem);
    }
  }
</style>
