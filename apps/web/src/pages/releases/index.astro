---
import { Image } from 'astro:assets';
import ReleaseCard from '@/components/cards/ReleaseCard.astro';
import MusicStreamingServiceListenTrigger from '@/components/music/MusicStreamingServiceListenTrigger.astro';
import SiteLayout from '@/layouts/SiteLayout.astro';
import {
  createReleaseDetailPath,
  listArtistProfiles,
  listReleaseCatalog,
  mapArtistProfilesById,
  resolveReleaseArtistDisplayName,
} from '@/lib/catalog-data';
import { getReleaseCommerceLink } from '@/lib/release-commerce';
import { isReleaseOutNow, selectReleasePageEntries } from '@/lib/release-feature';
import { formatDayMonthYear, formatMonthYear } from '@/utils/content';
import { buildEmbeddedPlayerData } from '@/utils/music';

const artistProfiles = await listArtistProfiles();
const releaseCatalogEntries = await listReleaseCatalog();
const artistProfileById = mapArtistProfilesById(artistProfiles);
const {
  featuredReleaseEntry: latestReleaseEntry,
  upcomingReleaseEntry,
  remainingReleaseEntries,
} = selectReleasePageEntries(releaseCatalogEntries);
const latestReleaseArtist = latestReleaseEntry ? artistProfileById.get(latestReleaseEntry.data.artist.id) : undefined;
const latestReleaseArtistName = latestReleaseEntry
  ? resolveReleaseArtistDisplayName(latestReleaseEntry, latestReleaseArtist)
  : '';
const latestReleasePlayerData = latestReleaseEntry
  ? buildEmbeddedPlayerData(
      latestReleaseEntry.id,
      latestReleaseEntry.data,
      `${latestReleaseEntry.data.title} - ${latestReleaseArtistName}`,
    )
  : null;
const latestReleaseCommerceLink = latestReleaseEntry ? await getReleaseCommerceLink(latestReleaseEntry) : null;
const latestReleaseDetailPath = latestReleaseEntry ? createReleaseDetailPath(latestReleaseEntry) : '';
const latestReleaseLabel =
  latestReleaseEntry?.data.release_date && isReleaseOutNow(latestReleaseEntry.data.release_date)
    ? 'Latest out now'
    : 'Next release';
const latestReleaseDate = latestReleaseEntry ? formatMonthYear(latestReleaseEntry.data.release_date) : '';
const latestReleaseDateMachineValue = latestReleaseEntry
  ? latestReleaseEntry.data.release_date.toISOString().slice(0, 10)
  : '';
const hasLatestReleaseActions = Boolean(latestReleasePlayerData || latestReleaseCommerceLink);
const upcomingReleaseArtist = upcomingReleaseEntry
  ? artistProfileById.get(upcomingReleaseEntry.data.artist.id)
  : undefined;
const upcomingReleaseArtistName = upcomingReleaseEntry
  ? resolveReleaseArtistDisplayName(upcomingReleaseEntry, upcomingReleaseArtist)
  : '';
const upcomingReleaseDetailPath = upcomingReleaseEntry ? createReleaseDetailPath(upcomingReleaseEntry) : '';
const upcomingReleaseDate = upcomingReleaseEntry ? formatDayMonthYear(upcomingReleaseEntry.data.release_date) : '';
const upcomingReleaseDateMachineValue = upcomingReleaseEntry
  ? upcomingReleaseEntry.data.release_date.toISOString().slice(0, 10)
  : '';

function formatReleaseFormats(formats: string[] | undefined) {
  return formats?.length ? formats.join(' / ') : 'Release';
}
---

<SiteLayout pageTitle="Releases" pageDescription="Releases and label catalog.">
  <header class="layout-container releases-page-intro">
    <p class="releases-page-intro__eyebrow">Catalog</p>
    <h1 class="releases-page-intro__title internal-page-hero__title" transition:name="internal-page-hero-title">
      Releases
    </h1>
  </header>
  {
    (latestReleaseEntry || upcomingReleaseEntry || remainingReleaseEntries.length > 0) && (
      <div class="layout-container releases-page-showcase-container">
        <div
          class:list={[
            'releases-page-layout',
            (!latestReleaseEntry || !upcomingReleaseEntry) && 'releases-page-layout--single-column',
          ]}
        >
          {latestReleaseEntry && (
            <article class="releases-latest-feature">
              <a class="releases-latest-feature__artwork-link" href={latestReleaseDetailPath} data-astro-prefetch>
                <Image
                  src={latestReleaseEntry.data.cover_image}
                  alt={latestReleaseEntry.data.cover_image_alt || latestReleaseEntry.data.title}
                  class="releases-latest-feature__artwork"
                  priority
                  widths={[720, 1080, 1440, 1800]}
                  sizes="(min-width: 1100px) 42vw, 100vw"
                />
              </a>
              <div class="releases-latest-feature__copy">
                <p class="releases-latest-feature__label">{latestReleaseLabel}</p>
                <h2 class="releases-latest-feature__heading">
                  <a class="releases-latest-feature__title" href={latestReleaseDetailPath} data-astro-prefetch>
                    {latestReleaseEntry.data.title}
                  </a>
                </h2>
                <p class="releases-latest-feature__meta">
                  {latestReleaseArtistName} / <time datetime={latestReleaseDateMachineValue}>{latestReleaseDate}</time>{' '}
                  / {formatReleaseFormats(latestReleaseEntry.data.formats)}
                </p>
                {latestReleaseEntry.data.summary && (
                  <p class="releases-latest-feature__summary">{latestReleaseEntry.data.summary}</p>
                )}
                {hasLatestReleaseActions && (
                  <div class="releases-latest-feature__actions">
                    {latestReleasePlayerData && (
                      <MusicStreamingServiceListenTrigger
                        embeddedPlayerData={latestReleasePlayerData}
                        tone="accent"
                        variant="standalone"
                      />
                    )}
                    <a class="releases-latest-feature__action-link" href={latestReleaseDetailPath} data-astro-prefetch>
                      View Release
                    </a>
                    {latestReleaseCommerceLink && (
                      <a
                        class="releases-latest-feature__action-link"
                        href={latestReleaseCommerceLink.href}
                        rel={latestReleaseCommerceLink.rel}
                        target={latestReleaseCommerceLink.target}
                      >
                        {latestReleaseCommerceLink.label}
                      </a>
                    )}
                  </div>
                )}
              </div>
            </article>
          )}
          {upcomingReleaseEntry && (
            <section class="releases-latest-feature__upcoming" aria-labelledby="releases-upcoming-heading">
              <a
                class="releases-latest-feature__upcoming-artwork-link"
                href={upcomingReleaseDetailPath}
                data-astro-prefetch
              >
                <Image
                  src={upcomingReleaseEntry.data.cover_image}
                  alt={upcomingReleaseEntry.data.cover_image_alt || upcomingReleaseEntry.data.title}
                  class="releases-latest-feature__upcoming-artwork"
                  loading="lazy"
                  widths={[240, 360, 480, 640]}
                  sizes="(min-width: 1024px) 22vw, (min-width: 640px) 10rem, 8.5rem"
                />
              </a>
              <div class="releases-latest-feature__upcoming-copy">
                <h2 id="releases-upcoming-heading" class="releases-latest-feature__label">
                  Upcoming
                </h2>
                <h3 class="releases-latest-feature__upcoming-heading">
                  <a
                    class="releases-latest-feature__upcoming-title"
                    href={upcomingReleaseDetailPath}
                    data-astro-prefetch
                  >
                    {upcomingReleaseEntry.data.title}
                  </a>
                </h3>
                <p class="releases-latest-feature__upcoming-meta">
                  {upcomingReleaseArtistName} /{' '}
                  <time datetime={upcomingReleaseDateMachineValue}>{upcomingReleaseDate}</time>
                </p>
                {upcomingReleaseEntry.data.summary && (
                  <p class="releases-latest-feature__upcoming-summary">{upcomingReleaseEntry.data.summary}</p>
                )}
                {upcomingReleaseEntry.data.formats?.length && (
                  <p class="releases-latest-feature__upcoming-formats">
                    {formatReleaseFormats(upcomingReleaseEntry.data.formats)}
                  </p>
                )}
              </div>
            </section>
          )}
          {remainingReleaseEntries.length > 0 && (
            <section class="releases-catalog-section" aria-labelledby="releases-catalog-heading">
              <h2 id="releases-catalog-heading" class="releases-catalog-section__heading">
                Our Releases
              </h2>
              <div class="releases-catalog-grid grid gap-5 md:grid-cols-2 xl:grid-cols-3">
                {remainingReleaseEntries.map((releaseEntry, index) => {
                  const artistProfile = artistProfileById.get(releaseEntry.data.artist.id);
                  return (
                    <ReleaseCard
                      release={releaseEntry}
                      artist={artistProfile}
                      imageLoading={index < 3 ? 'eager' : 'lazy'}
                      variant="framed-artwork"
                    />
                  );
                })}
              </div>
            </section>
          )}
        </div>
      </div>
    )
  }
</SiteLayout>
