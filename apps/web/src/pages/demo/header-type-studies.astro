---
import { existsSync } from 'node:fs';
import { fileURLToPath } from 'node:url';

import { Image } from 'astro:assets';
import { createAbsoluteSiteUrl, createProjectRelativeUrl, siteBrandAssets } from '@/config/site';
import {
  listArtistProfiles,
  listDistroEntries,
  listNewsArticles,
  listReleaseCatalog,
  resolveArtistProfileForRelease,
  resolveReleaseArtistDisplayName,
} from '@/lib/catalog-data';
import { formatYear } from '@/utils/content';

type SelfHostedFontDirectory = 'brand' | 'type-studies';

type FontCandidate = {
  id: string;
  name: string;
  fontFamily: string;
  opticalScale: number;
  fileName?: string;
  directory?: SelfHostedFontDirectory;
};

const pageTitle = 'Blackbox Records | Header Type Studies';
const pageDescription =
  'A noindex typography draft page for reviewing display-header directions against real BlackBox Records content.';
const pageUrl = createAbsoluteSiteUrl('/demo/header-type-studies/');
const faviconSvgUrl = createProjectRelativeUrl(siteBrandAssets.faviconSvg);
const faviconPngUrl = createProjectRelativeUrl(siteBrandAssets.faviconPng96);
const faviconIcoUrl = createProjectRelativeUrl(siteBrandAssets.faviconIco);
const selfHostedFontDirectories = {
  brand: {
    directory: new URL('../../../public/assets/fonts/brand/', import.meta.url),
  },
  'type-studies': {
    directory: new URL('../../../public/assets/fonts/type-studies/', import.meta.url),
  },
};

function hasSelfHostedFont(fileName: string, directory: SelfHostedFontDirectory = 'type-studies') {
  const fontDirectory = selfHostedFontDirectories[directory];
  return existsSync(fileURLToPath(new URL(fileName, fontDirectory.directory)));
}

const [artistProfiles, releaseCatalog, newsArticles, distroEntries] = await Promise.all([
  listArtistProfiles(),
  listReleaseCatalog(),
  listNewsArticles(),
  listDistroEntries(),
]);

const releaseEntry = releaseCatalog.find((entry) => entry.data.title === 'Disintegration') || releaseCatalog[0];
const releaseArtistProfile = releaseEntry ? await resolveArtistProfileForRelease(releaseEntry) : undefined;
const artistEntry = artistProfiles.find((entry) => entry.data.title === 'Afterwise') || artistProfiles[0];
const distroEntry =
  distroEntries.find((entry) => entry.data.title === 'Against His-Story, Against Leviathan!') || distroEntries[0];
const newsEntry = newsArticles[0];

const fontCandidates = [
  {
    id: '01',
    name: 'Road Rage',
    fontFamily: 'Road Rage',
    opticalScale: 1.08,
  },
  {
    id: '02',
    name: 'Changa',
    fontFamily: 'Changa',
    opticalScale: 0.94,
  },
  {
    id: '03',
    name: 'Veneer',
    fontFamily: 'Veneer',
    opticalScale: 1.02,
    directory: 'brand',
    fileName: 'veneer_regular.woff2',
  },
  {
    id: '04',
    name: 'Druk Text Wide Medium',
    fontFamily: 'Druk Text Wide Medium',
    opticalScale: 0.9,
    fileName: 'DrukTextWide-Medium-Trial.otf',
  },
] satisfies FontCandidate[];

const reviewedCandidates = fontCandidates.map((candidate) => ({
  ...candidate,
  isMissing: candidate.fileName ? !hasSelfHostedFont(candidate.fileName, candidate.directory) : false,
}));

const previewCandidates = reviewedCandidates.map(({ id, name, fontFamily, isMissing, opticalScale }) => ({
  fontFamily,
  id,
  isMissing,
  name,
  opticalScale,
}));
const previewCandidateJson = JSON.stringify(previewCandidates);

const mockReleaseTitle = releaseEntry?.data.title || 'Disintegration';
const mockReleaseArtist = releaseEntry
  ? resolveReleaseArtistDisplayName(releaseEntry, releaseArtistProfile || undefined)
  : 'Afterwise';
const mockReleaseSummary =
  releaseEntry?.data.summary ||
  'Afterwise shape post-rock weight, cinematic build-ups, and a severe visual system around the first BlackBox Records release.';
const mockReleaseYear = releaseEntry ? formatYear(releaseEntry.data.release_date) : '2026';
const mockReleaseFormats = releaseEntry?.data.formats?.join(' / ') || 'Vinyl 12-inch';
const mockReleaseImage = releaseEntry?.data.cover_image;
const mockReleaseImageAlt = releaseEntry?.data.cover_image_alt || mockReleaseTitle;
const mockArtistTitle = artistEntry?.data.title || 'Afterwise';
const mockDistroTitle = distroEntry?.data.title || 'Against His-Story, Against Leviathan!';
const mockDistroMeta = distroEntry
  ? `${distroEntry.data.artist_or_label} / ${distroEntry.data.group}`
  : 'Hazarder / Vinyl 12-inch';
const mockNewsTitle = newsEntry?.data.title || 'Caregivers by Chronoboros';
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={pageDescription} />
    <meta name="robots" content="noindex, nofollow" />
    <link rel="canonical" href={pageUrl} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={pageDescription} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={pageUrl} />
    <meta name="twitter:card" content="summary" />
    <meta name="theme-color" content="#050505" />
    <link rel="icon" href={faviconSvgUrl} type="image/svg+xml" sizes="any" />
    <link rel="icon" href={faviconPngUrl} type="image/png" sizes="96x96" />
    <link rel="icon" href={faviconIcoUrl} sizes="any" />
    <title>{pageTitle}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Changa:wght@800&family=Inter:wght@300;400;500;600;700&family=Road+Rage&display=swap"
      rel="stylesheet"
    />
    <link rel="stylesheet" href={createProjectRelativeUrl('/assets/fonts/brand/veneer.css')} />
    <link rel="stylesheet" href={createProjectRelativeUrl('/assets/fonts/type-studies/druk-text-wide.css')} />
    <script id="font-preview-candidates" is:inline type="application/json" set:html={previewCandidateJson} />
  </head>
  <body>
    <main class="type-lab">
      <section class="mock-preview" aria-labelledby="mock-preview-title" data-font-preview-root>
        <div class="mock-preview__toolbar">
          <div>
            <p class="section-label">Mock website preview</p>
            <h2 id="mock-preview-title">Applied to a site slice</h2>
          </div>
          <div class="mock-preview__controls">
            <p class="mock-preview__active" data-font-preview-label>Previewing: Bebas Neue</p>
            <button class="mock-preview__baseline-button" type="button" data-font-preview-baseline aria-pressed="true">
              Bebas Neue
            </button>
          </div>
        </div>

        <article class="mock-site" aria-label="Mock BlackBox Records latest release section">
          <div class="mock-site__page-label">
            <p class="mock-site__label">Releases</p>
            <p>Section mock based on the current latest-release block.</p>
          </div>

          <section class="mock-site__latest" aria-labelledby="mock-release-title">
            {
              mockReleaseImage && (
                <div class="mock-site__artwork-frame">
                  <Image
                    src={mockReleaseImage}
                    alt={mockReleaseImageAlt}
                    class="mock-site__artwork"
                    sizes="(min-width: 960px) 22rem, 100vw"
                  />
                </div>
              )
            }

            <div class="mock-site__copy">
              <p class="mock-site__label">Latest release</p>
              <h3 id="mock-release-title" class="mock-site__title" data-font-fit-frame style="overflow: hidden;">
                <span class="font-fit__reference" data-font-fit-reference aria-hidden="true">
                  {mockReleaseTitle}
                </span>
                <span class="font-fit__text" data-font-fit-text>{mockReleaseTitle}</span>
              </h3>
              <p class="mock-site__meta">
                {mockReleaseArtist} / {mockReleaseYear} / {mockReleaseFormats}
              </p>
              <p class="mock-site__summary">{mockReleaseSummary}</p>
              <div class="mock-site__actions">
                <a href="#mock-release-title">View release</a>
                <button type="button">Listen</button>
              </div>
            </div>
          </section>

          <div class="mock-site__related" aria-label="Related site item rows">
            <article>
              <p class="mock-site__label">Artist</p>
              <h4 class="mock-site__card-title" data-font-fit-frame>
                <span class="font-fit__reference" data-font-fit-reference aria-hidden="true">{mockArtistTitle}</span>
                <span class="font-fit__text" data-font-fit-text>{mockArtistTitle}</span>
              </h4>
              <p class="mock-site__meta">{mockReleaseArtist}</p>
            </article>
            <article>
              <p class="mock-site__label">Distro</p>
              <h4 class="mock-site__card-title" data-font-fit-frame>
                <span class="font-fit__reference" data-font-fit-reference aria-hidden="true">{mockDistroTitle}</span>
                <span class="font-fit__text" data-font-fit-text>{mockDistroTitle}</span>
              </h4>
              <p class="mock-site__meta">{mockDistroMeta}</p>
            </article>
            <article>
              <p class="mock-site__label">News</p>
              <h4 class="mock-site__card-title" data-font-fit-frame>
                <span class="font-fit__reference" data-font-fit-reference aria-hidden="true">{mockNewsTitle}</span>
                <span class="font-fit__text" data-font-fit-text>{mockNewsTitle}</span>
              </h4>
              <p class="mock-site__meta">BlackBox Records</p>
            </article>
          </div>
        </article>
      </section>

      <section class="study-grid" aria-label="Typography candidates">
        {
          reviewedCandidates.map((study) => (
            <article class:list={['study-card', study.isMissing && 'is-missing']}>
              <p
                class="study-card__sample"
                data-study-fit-frame
                style={`--candidate-font: '${study.fontFamily}', var(--font-current);`}
              >
                <span class="font-fit__reference" data-study-fit-reference aria-hidden="true">
                  Release
                </span>
                <span class="font-fit__text" data-study-fit-text>
                  Release
                </span>
              </p>
              <button
                class="study-card__preview-button"
                type="button"
                data-font-preview-button
                data-font-id={study.id}
                aria-label={`Apply ${study.name}${study.isMissing ? ', add licensed woff2 file first' : ''}`}
                aria-pressed="false"
                disabled={study.isMissing}
              >
                {study.name}
              </button>
            </article>
          ))
        }
      </section>
    </main>
    <script is:inline>
      (() => {
        const candidateDataElement = document.getElementById('font-preview-candidates');
        const previewRoot = document.querySelector('[data-font-preview-root]');
        const previewLabel = document.querySelector('[data-font-preview-label]');
        const previewFitFrames = Array.from(previewRoot?.querySelectorAll('[data-font-fit-frame]') || []);
        const studyFitFrames = Array.from(document.querySelectorAll('[data-study-fit-frame]'));
        const baselineButton = document.querySelector('[data-font-preview-baseline]');
        const previewButtons = Array.from(document.querySelectorAll('[data-font-preview-button]'));

        if (!candidateDataElement || !previewRoot || !previewLabel || previewButtons.length === 0) {
          return;
        }

        let candidates;

        try {
          candidates = JSON.parse(candidateDataElement.textContent || '[]');
        } catch {
          return;
        }

        const candidateById = new Map(candidates.map((candidate) => [candidate.id, candidate]));
        const baselineCandidate = {
          fontFamily: 'Bebas Neue',
          id: 'baseline',
          name: 'Bebas Neue',
          opticalScale: 1,
        };

        function createFontStack(fontFamily) {
          return `'${fontFamily}', var(--font-current)`;
        }

        function resetFit(frame) {
          frame.style.setProperty('--font-fit-x', '1');
          frame.style.setProperty('--font-fit-y', '1');
        }

        function fitFrame(frame, referenceSelector, textSelector) {
          const reference = frame.querySelector(referenceSelector);
          const text = frame.querySelector(textSelector);

          if (!reference || !text) {
            return;
          }

          resetFit(frame);

          const referenceRect = reference.getBoundingClientRect();
          const textRect = text.getBoundingClientRect();
          const frameWidth = frame.clientWidth;

          if (referenceRect.width <= 0 || referenceRect.height <= 0 || textRect.width <= 0 || textRect.height <= 0) {
            return;
          }

          const widthFit = Math.min(referenceRect.width / textRect.width, (frameWidth * 0.98) / textRect.width);
          const heightFit = referenceRect.height / textRect.height;
          const fitX = Number.isFinite(widthFit) ? Math.min(2.2, Math.max(0.08, widthFit)) : 1;
          const fitY = Number.isFinite(heightFit) ? Math.min(1.35, Math.max(0.62, heightFit)) : 1;

          frame.style.setProperty('--font-fit-x', fitX.toFixed(4));
          frame.style.setProperty('--font-fit-y', fitY.toFixed(4));
        }

        function fitPreviewText() {
          requestAnimationFrame(() => {
            requestAnimationFrame(() => {
              previewFitFrames.forEach((frame) => {
                fitFrame(frame, '[data-font-fit-reference]', '[data-font-fit-text]');
              });
            });
          });
        }

        function fitStudySamples() {
          studyFitFrames.forEach((frame) => {
            fitFrame(frame, '[data-study-fit-reference]', '[data-study-fit-text]');
          });
        }

        function scheduleTextFit(fontFamily) {
          fitPreviewText();
          fitStudySamples();
          window.setTimeout(fitPreviewText, 90);
          window.setTimeout(fitStudySamples, 90);
          window.setTimeout(fitPreviewText, 220);
          window.setTimeout(fitStudySamples, 220);
          window.setTimeout(fitPreviewText, 420);
          window.setTimeout(fitStudySamples, 420);
          document.fonts
            ?.load(`1em "${fontFamily.replace(/"/g, '')}"`)
            .then(() => {
              fitPreviewText();
              fitStudySamples();
              window.setTimeout(fitPreviewText, 90);
              window.setTimeout(fitStudySamples, 90);
            })
            .catch(() => {});
        }

        function setActiveCandidate(candidate) {
          previewRoot.style.setProperty('--active-preview-font', createFontStack(candidate.fontFamily));
          previewLabel.textContent = `Previewing: ${candidate.name}`;

          baselineButton?.setAttribute('aria-pressed', candidate.id === 'baseline' ? 'true' : 'false');

          previewButtons.forEach((button) => {
            button.setAttribute('aria-pressed', button.dataset.fontId === candidate.id ? 'true' : 'false');
          });

          scheduleTextFit(candidate.fontFamily);
          document.fonts?.ready
            .then(() => {
              fitPreviewText();
              fitStudySamples();
            })
            .catch(() => {});
        }

        previewButtons.forEach((button) => {
          button.addEventListener('click', () => {
            const candidate = candidateById.get(button.dataset.fontId);

            if (!candidate || candidate.isMissing) {
              return;
            }

            setActiveCandidate(candidate);
          });
        });

        baselineButton?.addEventListener('click', () => {
          setActiveCandidate(baselineCandidate);
        });

        document.fonts?.ready
          .then(() => {
            fitPreviewText();
            fitStudySamples();
          })
          .catch(() => {
            fitPreviewText();
            fitStudySamples();
          });
        fitPreviewText();
        fitStudySamples();
      })();
    </script>
  </body>
</html>

<style>
  :root {
    color-scheme: dark;
    --bg: #050505;
    --surface: #101010;
    --panel: #151515;
    --panel-strong: #1b1b1b;
    --line: #2b2b2b;
    --line-soft: rgba(245, 245, 245, 0.1);
    --text: #f3f1ed;
    --muted: #a8a39b;
    --muted-strong: #d7d0c5;
    --accent: #b44b58;
    --font-body: 'Inter', 'Helvetica Neue', Arial, sans-serif;
    --font-current: 'Bebas Neue', 'Impact', sans-serif;
  }

  * {
    box-sizing: border-box;
  }

  html,
  body {
    margin: 0;
    min-height: 100%;
    overflow-x: clip;
    background: var(--bg);
    color: var(--text);
  }

  body {
    font-family: var(--font-body);
    text-rendering: geometricprecision;
  }

  .type-lab {
    width: min(1500px, calc(100vw - 2rem));
    margin: 0 auto;
    padding: clamp(1rem, 2vw, 1.5rem) 0 clamp(2rem, 5vw, 4rem);
  }

  .section-label,
  .mock-site__label {
    margin: 0;
    color: var(--muted);
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.14em;
    line-height: 1.3;
    text-transform: uppercase;
  }

  .mock-preview {
    --active-preview-font: var(--font-current);
    --mock-display-xl: clamp(3.2rem, 5.8vw, 4.4rem);
    --mock-display-md: clamp(1.65rem, 3.2vw, 2.5rem);
  }

  .mock-preview__toolbar {
    display: grid;
    grid-template-columns: minmax(0, 1fr) auto;
    gap: 1rem;
    align-items: end;
  }

  .mock-preview__active {
    margin: 0;
    padding: 0.5rem 0.6rem;
    border: 1px solid var(--line);
    background: var(--surface);
    color: var(--muted-strong);
    font-size: 0.82rem;
    font-weight: 700;
    line-height: 1.2;
  }

  .mock-preview__controls {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    justify-content: flex-end;
  }

  .mock-preview__baseline-button {
    padding: 0.5rem 0.6rem;
    border: 1px solid var(--line);
    border-radius: 0;
    background: var(--surface);
    color: var(--text);
    cursor: pointer;
    font-family: var(--font-body);
    font-size: 0.82rem;
    font-weight: 700;
    line-height: 1.2;
  }

  .mock-preview__baseline-button:hover,
  .mock-preview__baseline-button:focus-visible,
  .mock-preview__baseline-button[aria-pressed='true'] {
    border-color: var(--muted-strong);
    background: var(--panel-strong);
  }

  .mock-site {
    margin-top: 1rem;
    border: 1px solid var(--line);
    background: var(--surface);
  }

  .mock-site__title,
  .mock-site__card-title {
    --font-fit-x: 1;
    --font-fit-y: 1;
    margin: 0;
    font-family: var(--active-preview-font);
    font-weight: 400;
    line-height: 0.88;
    text-transform: uppercase;
  }

  .mock-site__page-label {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem 1rem;
    align-items: center;
    justify-content: space-between;
    padding: 0.8rem 1rem;
    border-bottom: 1px solid var(--line);
  }

  .mock-site__page-label p:last-child {
    margin: 0;
    color: var(--muted-strong);
    font-size: 0.82rem;
    line-height: 1.4;
  }

  .mock-site__latest {
    display: grid;
    grid-template-columns: minmax(14rem, 0.36fr) minmax(0, 0.64fr);
    gap: clamp(1rem, 4vw, 2rem);
    align-items: center;
    padding: clamp(1rem, 3vw, 1.5rem);
    border-bottom: 1px solid var(--line);
  }

  .mock-site__artwork-frame {
    aspect-ratio: 1;
    min-width: 0;
    overflow: hidden;
    border: 1px solid var(--line);
    background: var(--panel);
  }

  .mock-site__artwork {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .mock-site__copy {
    min-width: 0;
  }

  .mock-site__title {
    max-width: none;
    line-height: 1;
    margin-top: 0.55rem;
    font-size: var(--mock-display-xl);
    overflow: hidden;
    position: relative;
    white-space: nowrap;
  }

  .font-fit__text {
    display: inline-block;
    max-width: none;
    transform: scale(var(--font-fit-x), var(--font-fit-y));
    transform-origin: left center;
    white-space: nowrap;
  }

  .font-fit__reference {
    position: absolute;
    inset: 0 auto auto 0;
    display: inline-block;
    pointer-events: none;
    transform: none;
    visibility: hidden;
    white-space: nowrap;
  }

  .mock-site__card-title {
    position: relative;
    margin-top: 0.5rem;
    font-size: var(--mock-display-md);
    overflow-wrap: anywhere;
  }

  .mock-site__title .font-fit__reference,
  .mock-site__card-title .font-fit__reference {
    font-family: var(--font-current);
  }

  .mock-site__meta,
  .mock-site__summary {
    margin: 0;
    color: var(--muted-strong);
    font-family: var(--font-body);
    line-height: 1.55;
  }

  .mock-site__meta {
    margin-top: 0.65rem;
    color: var(--muted);
    font-size: 0.86rem;
    font-weight: 700;
  }

  .mock-site__summary {
    max-width: 66ch;
    margin-top: 1rem;
    font-size: 0.98rem;
  }

  .mock-site__actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-top: 1.1rem;
  }

  .mock-site__actions a,
  .mock-site__actions button {
    padding: 0.55rem 0.65rem;
    border: 1px solid var(--line);
    color: var(--muted-strong);
    font-family: var(--font-body);
    font-size: 0.82rem;
    font-weight: 700;
    line-height: 1.2;
    text-decoration: none;
  }

  .mock-site__actions button {
    border-radius: 0;
    background: transparent;
    cursor: pointer;
  }

  .mock-site__actions a:hover,
  .mock-site__actions a:focus-visible,
  .mock-site__actions button:hover,
  .mock-site__actions button:focus-visible {
    border-color: var(--muted-strong);
    color: var(--text);
  }

  .mock-site__related {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 1px;
    background: var(--line);
  }

  .mock-site__related article {
    min-width: 0;
    padding: 1rem;
    background: var(--panel);
  }

  .study-grid {
    display: grid;
    grid-template-columns: repeat(6, minmax(0, 1fr));
    gap: 1px;
    margin-top: 1rem;
    background: var(--line);
    border: 1px solid var(--line);
  }

  .study-card {
    display: grid;
    min-width: 0;
    gap: 0.45rem;
    padding: 0.55rem;
    background: var(--panel);
  }

  .study-card__sample {
    --font-fit-x: 1;
    --font-fit-y: 1;
    min-width: 0;
    margin: 0;
    color: var(--text);
    font-family: var(--candidate-font);
    font-size: clamp(1.2rem, 1.8vw, 1.75rem);
    font-weight: 400;
    line-height: 0.9;
    overflow: hidden;
    text-overflow: clip;
    text-transform: uppercase;
    white-space: nowrap;
    position: relative;
  }

  .study-card__sample .font-fit__reference {
    font-family: var(--font-current);
  }

  .study-card__sample .font-fit__text {
    font-family: var(--candidate-font);
  }

  .study-card__preview-button {
    width: 100%;
    min-width: 0;
    padding: 0.42rem 0.45rem;
    border: 1px solid var(--line);
    border-radius: 0;
    background: var(--surface);
    color: var(--text);
    cursor: pointer;
    font-family: var(--font-body);
    font-size: 0.72rem;
    font-weight: 700;
    line-height: 1.2;
    overflow: hidden;
    text-align: left;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  .study-card__preview-button:hover,
  .study-card__preview-button:focus-visible,
  .study-card__preview-button[aria-pressed='true'] {
    border-color: var(--muted-strong);
    background: var(--panel-strong);
  }

  .study-card__preview-button:disabled {
    cursor: not-allowed;
    color: var(--muted);
    opacity: 0.56;
