---
import { createProjectRelativeUrl, siteBrandAssets, siteConfig } from '@/config/site';

const pageTitle = 'Favicon Review | Blackbox Records';
const currentFaviconUrl = createProjectRelativeUrl(siteBrandAssets.faviconSvg);
const currentFaviconPngUrl = createProjectRelativeUrl(siteBrandAssets.faviconPng96);
const currentFaviconIcoUrl = createProjectRelativeUrl(siteBrandAssets.faviconIco);

const recoveredIcoNote =
  'The pre-SVG ICO from git history was extracted, but it renders as a circular crest rather than the larger cube shown in the approval screenshot.';

const candidateASvg = `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 64 64" role="img" aria-label="Blackbox Records cube favicon candidate A">
  <g fill="none" stroke="#f4f1f8" stroke-linecap="round" stroke-linejoin="round" stroke-width="4.6">
    <path d="M32 6.5 56.5 20.6 32 34.8 7.5 20.6 32 6.5Z"/>
    <path d="M7.5 20.6v25.1L32 59.5l24.5-13.8V20.6"/>
    <path d="M32 34.8v24.7"/>
    <path d="M42.4 39.7 51.4 34.6v18.2l-9 5Z"/>
  </g>
</svg>`;

const candidateBSvg = `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 64 64" role="img" aria-label="Blackbox Records cube favicon candidate B">
  <g fill="none" stroke="#f6f3fb" stroke-linecap="round" stroke-linejoin="round" stroke-width="5.2">
    <path d="M32 5.5 57.5 20.2 32 35 6.5 20.2 32 5.5Z"/>
    <path d="M6.5 20.2v25.9L32 60.5l25.5-14.4V20.2"/>
    <path d="M32 35v25.5"/>
    <path d="M42.8 40.2 51.8 35.1v18.7l-9 5.1Z"/>
  </g>
</svg>`;

function createSvgDataUri(svg: string) {
  return `data:image/svg+xml,${encodeURIComponent(svg)}`;
}

const reviewItems = [
  {
    id: 'current',
    label: 'Current production SVG',
    type: 'Reference',
    src: currentFaviconUrl,
    note: 'Loaded by production layouts before PNG and ICO fallbacks. This is the small/thin mark we are comparing against.',
  },
  {
    id: 'candidate-a',
    label: 'Candidate A - enlarged cube',
    type: 'SVG candidate',
    src: createSvgDataUri(candidateASvg),
    note: 'Bigger cube footprint, clean pale stroke, close to the left tab target without over-thickening the inner face.',
  },
  {
    id: 'candidate-b',
    label: 'Candidate B - small-size tuned',
    type: 'SVG candidate',
    src: createSvgDataUri(candidateBSvg),
    note: 'Tighter padding and heavier stroke for the 16px tab case. This is the safest candidate if the icon still reads too small.',
  },
];

const sampleSizes = [16, 24, 32];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="robots" content="noindex, nofollow" />
    <meta name="description" content="Noindex Blackbox Records favicon approval demo." />
    <title>{pageTitle}</title>
    <link rel="icon" href={currentFaviconUrl} type="image/svg+xml" sizes="any" />
    <link rel="icon" href={currentFaviconPngUrl} type="image/png" sizes="96x96" />
    <link rel="icon" href={currentFaviconIcoUrl} sizes="any" />
    <style>
      :root {
        color-scheme: dark;
        --review-bg: #080808;
        --review-panel: #101010;
        --review-panel-strong: #171717;
        --review-border: #2c2c2c;
        --review-text: #f4f1f8;
        --review-muted: #a8a3b4;
        --review-purple: #4d2384;
        --review-purple-border: #8255ce;
      }

      * {
        box-sizing: border-box;
      }

      body {
        margin: 0;
        background: var(--review-bg);
        color: var(--review-text);
        font:
          14px/1.5 ui-monospace,
          SFMono-Regular,
          Consolas,
          'Liberation Mono',
          monospace;
      }

      img {
        display: block;
      }

      .favicon-review {
        width: min(1180px, calc(100vw - 32px));
        margin: 0 auto;
        padding: 32px 0 48px;
      }

      .favicon-review__header {
        display: grid;
        gap: 12px;
        border-bottom: 1px solid var(--review-border);
        padding-bottom: 24px;
      }

      .favicon-review__header p,
      .favicon-review__note,
      .favicon-review__card p {
        margin: 0;
        color: var(--review-muted);
      }

      h1,
      h2,
      h3 {
        margin: 0;
        color: var(--review-text);
        font-weight: 700;
        letter-spacing: 0.04em;
        text-transform: uppercase;
      }

      h1 {
        font-size: clamp(2.2rem, 7vw, 5rem);
        line-height: 0.95;
      }

      h2 {
        font-size: 1rem;
      }

      h3 {
        font-size: 0.9rem;
      }

      .favicon-review__source {
        color: var(--review-muted);
        font-size: 0.76rem;
        text-transform: uppercase;
      }

      .favicon-review__summary {
        max-width: 76ch;
      }

      .favicon-review__note {
        border: 1px solid var(--review-border);
        background: var(--review-panel);
        padding: 12px 14px;
      }

      .favicon-review__grid {
        display: grid;
        gap: 16px;
        margin-top: 24px;
      }

      .favicon-review__card {
        display: grid;
        gap: 16px;
        border: 1px solid var(--review-border);
        background: var(--review-panel);
        padding: 16px;
      }

      .favicon-review__card-header {
        display: flex;
        flex-wrap: wrap;
        gap: 8px 14px;
        align-items: baseline;
        justify-content: space-between;
      }

      .favicon-review__type {
        color: var(--review-muted);
        font-size: 0.72rem;
        letter-spacing: 0.12em;
        text-transform: uppercase;
      }

      .favicon-review__samples {
        display: flex;
        flex-wrap: wrap;
        gap: 12px;
      }

      .favicon-review__sample {
        display: grid;
        min-width: 7rem;
        gap: 8px;
        border: 1px solid var(--review-border);
        background: #070707;
        padding: 12px;
      }

      .favicon-review__sample-frame {
        display: grid;
        width: 44px;
        height: 44px;
        place-items: center;
        background: #050505;
        border: 1px solid #202020;
      }

      .favicon-review__sample-label {
        color: var(--review-muted);
        font-size: 0.72rem;
        text-transform: uppercase;
      }

      .favicon-review__tab-strip {
        display: grid;
        gap: 8px;
        border: 1px solid var(--review-border);
        background: #151020;
        padding: 10px;
      }

      .favicon-review__tab {
        display: flex;
        width: min(100%, 280px);
        height: 36px;
        align-items: center;
        gap: 8px;
        border: 1px solid #2d243f;
        background: #191124;
        padding: 0 10px;
        color: #ddd8e8;
      }

      .favicon-review__tab--target {
        border-color: var(--review-purple-border);
        background: var(--review-purple);
      }

      .favicon-review__tab img {
        width: 16px;
        height: 16px;
        flex: none;
      }

      .favicon-review__tab-title {
        min-width: 0;
        flex: 1;
        overflow: hidden;
        text-overflow: ellipsis;
        white-space: nowrap;
      }

      .favicon-review__tab-close {
        color: #cfc8dc;
      }

      .favicon-review__current-pair {
        display: flex;
        flex-wrap: wrap;
        gap: 8px;
      }

      @media (min-width: 860px) {
        .favicon-review__card {
          grid-template-columns: minmax(0, 1fr) minmax(300px, 0.65fr);
          align-items: start;
        }

        .favicon-review__card-header,
        .favicon-review__card p,
        .favicon-review__samples {
          grid-column: 1;
        }

        .favicon-review__tab-strip {
          grid-column: 2;
          grid-row: 1 / span 3;
        }
      }
    </style>
  </head>
  <body>
    <main class="favicon-review">
      <header class="favicon-review__header">
        <p class="favicon-review__source">{siteConfig.title} / noindex demo</p>
        <h1>Favicon Review</h1>
        <p class="favicon-review__summary">
          Approval surface for choosing a larger cube favicon SVG before any production favicon files are replaced.
        </p>
        <p class="favicon-review__note">{recoveredIcoNote}</p>
      </header>

      <section class="favicon-review__grid" aria-label="Favicon candidates">
        {
          reviewItems.map((item) => (
            <article class="favicon-review__card" id={item.id}>
              <div class="favicon-review__card-header">
                <h2>{item.label}</h2>
                <span class="favicon-review__type">{item.type}</span>
              </div>

              <p>{item.note}</p>

              <div class="favicon-review__samples" aria-label={`${item.label} size samples`}>
                {sampleSizes.map((size) => (
                  <div class="favicon-review__sample">
                    <div class="favicon-review__sample-frame">
                      <img
                        src={item.src}
                        alt=""
                        width={size}
                        height={size}
                        style={`width: ${size}px; height: ${size}px;`}
                      />
                    </div>
                    <span class="favicon-review__sample-label">{size}px</span>
                  </div>
                ))}
              </div>

              <div class="favicon-review__tab-strip" aria-label={`${item.label} browser tab mockup`}>
                <div class="favicon-review__tab favicon-review__tab--target">
                  <img src={item.src} alt="" width="16" height="16" />
                  <span class="favicon-review__tab-title">Home | Blackbox</span>
                  <span class="favicon-review__tab-close" aria-hidden="true">
                    X
                  </span>
                </div>
                <div class="favicon-review__tab">
                  <img src={currentFaviconUrl} alt="" width="16" height="16" />
                  <span class="favicon-review__tab-title">Current favicon</span>
                  <span class="favicon-review__tab-close" aria-hidden="true">
                    X
                  </span>
                </div>
              </div>
            </article>
          ))
        }
      </section>
    </main>
  </body>
</html>
