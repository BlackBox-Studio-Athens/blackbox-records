---
import { createAbsoluteSiteUrl, createProjectRelativeUrl } from '@/config/site';

const pageTitle = 'Blackbox Records | Under Construction';
const pageDescription =
  'A local-only under-construction holding page study built as a direct MonoDeaf-style replica in Blackbox colors.';
const pageUrl = createAbsoluteSiteUrl('/demo/under-construction/');
const logoUrl = createProjectRelativeUrl('/assets/images/brand/logo.png');
const faviconUrl = createProjectRelativeUrl('/favicon.ico');
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={pageDescription} />
    <meta name="robots" content="noindex, nofollow" />
    <link rel="canonical" href={pageUrl} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={pageDescription} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={pageUrl} />
    <meta property="og:image" content={logoUrl} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="theme-color" content="#050505" />
    <link rel="icon" href={faviconUrl} sizes="any" />
    <title>{pageTitle}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Funnel+Display:wght@400;500;600;700&family=Instrument+Serif:ital@0;1&family=Inter:wght@400;500;600&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    <main class="page">
      <div class="page__grain" aria-hidden="true"></div>
      <div class="page__dust" aria-hidden="true"></div>
      <div class="page__vignette" aria-hidden="true"></div>

      <section class="hero">
        <div class="hero__masthead">
          <h1>BLACKBOX</h1>
        </div>

        <div class="hero__story">
          <div class="hero__story-title">
            <span>UNDER</span>
            <span>CONSTRUCTION</span>
          </div>

          <div class="hero__story-copy">
            <p>
              Blackbox Records is building its first public website: a dedicated home for artists, releases, distro,
              services, and label information.
            </p>
            <p>
              The public launch is not live yet. Internal users, label members, and collaborators can continue reviewing
              the private preview while the final structure is being staged.
            </p>
            <p>
              This temporary page stays minimal on purpose. It keeps the identity visible without exposing unfinished
              sections before they are ready.
            </p>
          </div>
        </div>

        <div class="hero__strip" aria-hidden="true">
          <div class="hero__strip-image">
            <img src={logoUrl} alt="" />
          </div>
        </div>

        <aside class="rail" aria-label="Utility rail">
          <section class="rail__panel rail__panel--brand">
            <p class="rail__brand">Blackbox<br />Records</p>
            <div class="rail__socials">
              <a href="javascript:void(0)">Spotify</a>
              <a href="javascript:void(0)">Bandcamp</a>
              <a href="javascript:void(0)">Instagram</a>
              <a href="javascript:void(0)">Email</a>
            </div>
          </section>

          <section class="rail__panel rail__panel--nav">
            <p class="rail__label">Navigation</p>
            <a href="javascript:void(0)">Home</a>
            <a href="javascript:void(0)">Artists</a>
            <a href="javascript:void(0)">Releases</a>
            <a href="javascript:void(0)">Distro</a>
            <a href="javascript:void(0)">Services</a>
          </section>

          <section class="rail__panel rail__panel--note">
            <p class="rail__label">Status</p>
            <p class="rail__microcopy">Public launch pending</p>
            <a class="rail__button" href="javascript:void(0)">Private preview active</a>
          </section>
        </aside>

        <div class="hero__footer-pill">
          <span>This site is currently a holding page while the full Blackbox Records website is prepared.</span>
          <a href="javascript:void(0)">Noted</a>
        </div>
      </section>
    </main>
  </body>
</html>

<style>
  :root {
    color-scheme: dark;
    --bg: #050505;
    --panel: rgba(255, 255, 255, 0.03);
    --line: rgba(255, 255, 255, 0.09);
    --text: #f1f1f1;
    --muted: #a0a0a0;
    --muted-soft: rgba(255, 255, 255, 0.4);
    --accent: #c8c2e3;
  }

  * {
    box-sizing: border-box;
  }

  html,
  body {
    margin: 0;
    min-height: 100%;
    background: var(--bg);
    color: var(--text);
    overflow-x: clip;
  }

  body {
    font-family: 'Inter', system-ui, sans-serif;
  }

  a {
    color: inherit;
    text-decoration: none;
  }

  img {
    display: block;
    max-width: 100%;
  }

  .page {
    position: relative;
    min-height: 100vh;
    background: #050505;
  }

  .page__grain,
  .page__dust,
  .page__vignette {
    position: fixed;
    inset: 0;
    pointer-events: none;
  }

  .page__grain {
    z-index: 2;
    opacity: 0.3;
    mix-blend-mode: screen;
    background-image:
      radial-gradient(circle at 15% 25%, rgba(255, 255, 255, 0.09), transparent 22%),
      radial-gradient(circle at 80% 10%, rgba(255, 255, 255, 0.08), transparent 24%),
      repeating-linear-gradient(0deg, rgba(255, 255, 255, 0.016) 0 1px, transparent 1px 4px),
      repeating-linear-gradient(90deg, rgba(255, 255, 255, 0.012) 0 1px, transparent 1px 3px);
    filter: contrast(1.25) brightness(1.05);
  }

  .page__dust {
    z-index: 3;
    opacity: 0.16;
    background-image:
      radial-gradient(circle at 12% 18%, rgba(255, 255, 255, 0.45) 0 1px, transparent 1.2px),
      radial-gradient(circle at 78% 31%, rgba(255, 255, 255, 0.35) 0 1px, transparent 1.2px),
      radial-gradient(circle at 58% 84%, rgba(255, 255, 255, 0.25) 0 1px, transparent 1.2px),
      radial-gradient(circle at 34% 72%, rgba(255, 255, 255, 0.28) 0 1px, transparent 1.2px);
    background-size:
      240px 240px,
      320px 320px,
      280px 280px,
      360px 360px;
  }

  .page__vignette {
    z-index: 1;
    background: radial-gradient(circle at center, transparent 52%, rgba(0, 0, 0, 0.5) 100%);
  }

  .hero {
    position: relative;
    z-index: 4;
    display: grid;
    grid-template-columns: minmax(0, 25rem) minmax(0, 1fr) 13.25rem;
    grid-template-rows: auto auto 1fr auto;
    column-gap: 1.4rem;
    row-gap: 1.1rem;
    width: min(1600px, calc(100vw - 2rem));
    min-height: 100vh;
    margin: 0 auto;
    padding: 1rem 0 1.4rem;
  }

  .hero__masthead {
    grid-column: 1 / 3;
    grid-row: 1;
  }

  .hero__masthead h1 {
    margin: 0;
    font-family: 'Funnel Display', sans-serif;
    font-size: clamp(4.5rem, 10vw, 9.6rem);
    line-height: 0.86;
    letter-spacing: -0.08em;
    text-transform: uppercase;
  }

  .hero__story {
    grid-column: 1;
    grid-row: 2;
    display: grid;
    gap: 0.65rem;
    align-content: start;
  }

  .hero__story-title {
    color: rgba(255, 255, 255, 0.44);
    font-family: 'Instrument Serif', serif;
    font-style: italic;
    font-size: clamp(1.8rem, 3vw, 3.3rem);
    line-height: 0.92;
  }

  .hero__story-title span {
    display: block;
  }

  .hero__story-copy {
    max-width: 24rem;
    color: var(--muted);
    font-size: 0.82rem;
    line-height: 1.45;
  }

  .hero__story-copy p {
    margin: 0 0 0.95rem;
  }

  .hero__strip {
    grid-column: 2;
    grid-row: 2;
    padding-top: 3.95rem;
  }

  .hero__strip-image {
    position: relative;
    height: clamp(12rem, 22vw, 16.5rem);
    overflow: clip;
    border: 1px solid var(--line);
    background: linear-gradient(90deg, #171717 0 12%, #2c2c2c 12% 42%, #0d0d0d 42% 100%);
  }

  .hero__strip-image::before {
    content: '';
    position: absolute;
    inset: 0;
    background:
      radial-gradient(circle at 62% 30%, rgba(255, 255, 255, 0.85), transparent 7%),
      radial-gradient(circle at 64% 33%, rgba(255, 255, 255, 0.36), transparent 20%),
      radial-gradient(circle at 54% 34%, rgba(0, 0, 0, 0.82), transparent 28%),
      linear-gradient(180deg, transparent 44%, rgba(0, 0, 0, 0.82) 100%);
    mix-blend-mode: screen;
    opacity: 0.98;
  }

  .hero__strip-image img {
    position: absolute;
    right: 3rem;
    top: 1.65rem;
    width: min(14rem, 28%);
    filter: grayscale(1) brightness(1.85) contrast(1.1) opacity(0.34);
    mix-blend-mode: screen;
  }

  .rail {
    grid-column: 3;
    grid-row: 1 / span 3;
    position: sticky;
    top: 1rem;
    align-self: start;
    display: grid;
    gap: 0;
    border: 1px solid var(--line);
    background: rgba(255, 255, 255, 0.02);
    backdrop-filter: blur(4px);
  }

  .rail__panel {
    padding: 1rem 0.95rem;
    border-bottom: 1px solid var(--line);
  }

  .rail__panel:last-of-type {
    border-bottom: 0;
  }

  .rail__brand {
    margin: 0 0 0.9rem;
    font-family: 'Inter', system-ui, sans-serif;
    font-size: 0.72rem;
    font-weight: 600;
    line-height: 1.2;
  }

  .rail__socials,
  .rail__panel--nav {
    display: grid;
    gap: 0.7rem;
  }

  .rail__socials a,
  .rail__panel--nav a {
    color: rgba(255, 255, 255, 0.72);
    font-size: 0.68rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .rail__label {
    margin: 0 0 0.85rem;
    color: var(--muted-soft);
    font-size: 0.72rem;
  }

  .rail__microcopy {
    margin: 0 0 0.85rem;
    color: rgba(255, 255, 255, 0.78);
    font-size: 0.78rem;
    line-height: 1.35;
  }

  .rail__button {
    display: flex;
    align-items: center;
    justify-content: center;
    min-height: 2rem;
    padding: 0.65rem 0.7rem;
    border-radius: 0.18rem;
    background: var(--accent);
    color: #121212;
    font-size: 0.68rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .hero__footer-pill {
    grid-column: 1;
    grid-row: 4;
    display: inline-flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    min-height: 2.65rem;
    max-width: 26.5rem;
    padding: 0.45rem 0.55rem 0.45rem 1rem;
    border: 1px solid var(--line);
    border-radius: 1rem;
    background: rgba(255, 255, 255, 0.03);
    color: rgba(255, 255, 255, 0.54);
    font-size: 0.58rem;
    line-height: 1.35;
    letter-spacing: 0.03em;
  }

  .hero__footer-pill a {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-width: 3rem;
    min-height: 1.8rem;
    padding: 0 0.8rem;
    border: 1px solid rgba(255, 255, 255, 0.18);
    border-radius: 999px;
    color: rgba(255, 255, 255, 0.75);
    font-size: 0.58rem;
  }

  @media (max-width: 1100px) {
    .hero {
      grid-template-columns: 1fr;
      grid-template-rows: auto auto auto auto auto;
    }

    .hero__masthead,
    .hero__story,
    .hero__strip,
    .rail,
    .hero__footer-pill {
      grid-column: 1;
      grid-row: auto;
    }

    .hero__strip {
      padding-top: 0;
    }

    .rail {
      position: relative;
      top: auto;
    }

    .hero__footer-pill {
      max-width: 100%;
    }
  }

  @media (max-width: 720px) {
    .hero {
      width: calc(100vw - 1rem);
      padding: 0.5rem 0 1rem;
      row-gap: 0.9rem;
    }

    .hero__masthead h1 {
      font-size: clamp(3rem, 18vw, 5rem);
    }

    .hero__story-title {
      font-size: 2rem;
    }

    .hero__story-copy {
      font-size: 0.78rem;
    }

    .hero__strip-image {
      height: 9rem;
    }

    .hero__strip-image img {
      right: 1rem;
      top: 1.1rem;
      width: 7rem;
    }

    .hero__footer-pill {
      flex-direction: column;
      align-items: stretch;
    }

    .hero__footer-pill a {
      align-self: end;
    }
  }
</style>
