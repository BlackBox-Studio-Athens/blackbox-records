---
import { Badge } from '@/components/ui/badge';
import { Card, CardContent } from '@/components/ui/card';
import CheckoutOrderSummary from '@/components/store/CheckoutOrderSummary';
import CheckoutOfferStatus from '@/components/store/CheckoutOfferStatus';
import { STORE_OFFER_PRICE_DISPLAY_COPY } from '@/components/store/StoreOfferPriceDisplay';
import { createProjectRelativeUrl } from '@/config/site';
import SiteLayout from '@/layouts/SiteLayout.astro';

const initialCheckoutAvailability = {
  canBuy: true,
  label: 'Cart checkout',
  optionLabel: null,
  priceDisplay: STORE_OFFER_PRICE_DISPLAY_COPY.loading,
};
const summaryItem = {
  availabilityLabel: 'Cart checkout',
  canBuy: true,
  image: null,
  imageAlt: 'Cart checkout',
  itemHref: createProjectRelativeUrl('/store/'),
  optionLabel: null,
  priceDisplay: STORE_OFFER_PRICE_DISPLAY_COPY.loading,
  subtitle: 'BlackBox Records',
  title: 'Cart Checkout',
};
---

<SiteLayout
  pageTitle="Checkout | Store"
  pageDescription="Review your cart, confirm Greece-only shipping, then pay through Stripe."
>
  <section class="layout-container pt-14 pb-8">
    <div class="mb-8 flex flex-wrap items-center justify-between gap-4">
      <div class="space-y-3">
        <Badge variant="outline" className="border-border/70 bg-background/80 text-xs tracking-[0.15em] uppercase">
          Cart Checkout
        </Badge>
        <div class="space-y-2">
          <h1 class="font-display text-5xl tracking-[0.08em] uppercase text-foreground sm:text-6xl">Checkout</h1>
          <p class="max-w-2xl text-sm leading-relaxed text-muted-foreground">
            Review the cart, confirm Greece-only shipping, then pay through Stripe.
          </p>
        </div>
      </div>
      <a
        href={createProjectRelativeUrl('/store/')}
        data-astro-prefetch
        class="text-[11px] font-semibold uppercase tracking-[0.18em] text-muted-foreground underline-offset-4 transition-colors hover:text-foreground hover:underline"
      >
        Continue Shopping
      </a>
    </div>

    <div
      class="grid min-w-0 grid-cols-1 gap-6 lg:grid-cols-[minmax(0,1fr)_24rem] xl:grid-cols-[minmax(40rem,1fr)_27rem]"
    >
      <div class="min-w-0 lg:hidden">
        <details class="group min-w-0 border border-border/70 bg-card/45" open>
          <summary
            class="flex cursor-pointer list-none items-center justify-between gap-3 px-4 py-4 text-[11px] font-semibold uppercase tracking-[0.18em] text-foreground marker:hidden sm:px-5"
          >
            <span class="min-w-0">Order Summary</span>
          </summary>
          <div class="min-w-0 border-t border-border/70 p-3 sm:p-4">
            <CheckoutOrderSummary client:load {...summaryItem} />
          </div>
        </details>
      </div>

      <Card className="min-w-0 rounded-none border-border/70 bg-card/35 shadow-none">
        <CardContent className="grid min-w-0 grid-cols-1 gap-6 p-5 sm:p-6 lg:p-8">
          <div class="flex flex-wrap items-center justify-between gap-4 border-b border-border/60 pb-5">
            <div class="space-y-2">
              <p class="text-[10px] uppercase tracking-[0.2em] text-muted-foreground">Checkout</p>
              <h2 class="font-display text-4xl tracking-[0.08em] uppercase text-foreground">Shipping & Payment</h2>
            </div>
            <span class="text-[10px] uppercase tracking-[0.18em] text-muted-foreground">Secure Stripe Checkout</span>
          </div>

          <CheckoutOfferStatus client:load initialAvailability={initialCheckoutAvailability} />
        </CardContent>
      </Card>

      <aside class="hidden lg:block">
        <div class="sticky top-[calc(var(--header-height)+2rem)]">
          <CheckoutOrderSummary client:load {...summaryItem} />
        </div>
      </aside>
    </div>
  </section>
</SiteLayout>
