---
import InternalPageHero from '@/components/InternalPageHero.astro';
import StoreItemCard from '@/components/cards/StoreItemCard.astro';
import SiteLayout from '@/layouts/SiteLayout.astro';
import { listStoreCollectionEntries } from '@/lib/store-collection';

const collectionEntries = await listStoreCollectionEntries();
---

<SiteLayout
  pageTitle="Store"
  pageDescription="A native BlackBox storefront layer built from releases and distro entries inside the site."
>
  <InternalPageHero sectionLabel="Store" title="Store" />

  <section class="layout-container pb-6">
    <div class="grid gap-6 border border-border/70 bg-card/35 p-6 md:grid-cols-[minmax(0,1.2fr)_minmax(18rem,0.8fr)] md:p-8">
      <div class="space-y-5">
        <p class="text-[11px] uppercase tracking-[0.22em] text-muted-foreground">Store shelf</p>
        <h2 class="max-w-3xl font-display text-4xl tracking-[0.1em] uppercase text-foreground md:text-5xl">
          One shelf for label releases, distro finds, and whatever still belongs in the room.
        </h2>
        <p class="max-w-2xl text-sm leading-relaxed text-muted-foreground md:text-base">
          The store stays inside the BlackBox language: restrained, monochrome, and closer to a label table than to a generic ecommerce grid.
        </p>
      </div>
      <div class="border-t border-border/60 pt-4 md:border-t-0 md:border-l md:pl-6 md:pt-0">
        <p class="text-[10px] uppercase tracking-[0.18em] text-muted-foreground">Current posture</p>
        <p class="mt-3 text-sm leading-relaxed text-muted-foreground">
          Product pages and the checkout shell are already native. Item availability is still temporary and deliberately calm, so unavailable items remain in view without loud stock theatre.
        </p>
      </div>
    </div>
  </section>

  <section class="layout-container pb-14" aria-label="Store collection">
    <div class="grid gap-6 md:grid-cols-2 xl:grid-cols-3">
      {collectionEntries.map((entry) => <StoreItemCard entry={entry} />)}
    </div>
  </section>
</SiteLayout>
