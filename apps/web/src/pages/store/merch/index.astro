---
import StoreCollectionPage from '@/components/store/StoreCollectionPage.astro';
import { createProjectRelativeUrl } from '@/config/site';
import RedirectLayout from '@/layouts/RedirectLayout.astro';
import { getStoreCatalogCategory } from '@/lib/store-categories';
import { listStoreCollectionEntries } from '@/lib/store-collection';

const collectionEntries = await listStoreCollectionEntries('merch');
const redirectUrl = createProjectRelativeUrl('/store/');
---

{
  collectionEntries.length === 0 ? (
    <RedirectLayout
      pageTitle="Merch"
      pageDescription="No BlackBox Records merch is currently available."
      redirectUrl={redirectUrl}
    >
      <p class="text-sm leading-relaxed text-muted-foreground">
        No merch is currently available.{' '}
        <a class="underline underline-offset-4" href={redirectUrl}>
          Browse Store
        </a>
        .
      </p>
    </RedirectLayout>
  ) : (
    <StoreCollectionPage category={getStoreCatalogCategory('merch')} entries={collectionEntries} />
  )
}
