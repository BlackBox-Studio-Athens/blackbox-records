---
import { Image } from 'astro:assets';

import { Badge } from '@/components/ui/badge';
import { buttonVariants } from '@/components/ui/button';
import { createProjectRelativeUrl } from '@/config/site';
import SiteLayout from '@/layouts/SiteLayout.astro';
import { type StorePageEntry, createStorePageStaticPaths } from '@/lib/store-page-data';
import { cn } from '@/lib/utils';

export async function getStaticPaths() {
  return createStorePageStaticPaths();
}

interface Props {
  entry: StorePageEntry;
}

const { entry } = Astro.props;
const { storeItem, primaryAvailability } = entry;
const metadataLabel = storeItem.metadata.join(' · ');
const priceLabel = primaryAvailability?.price.display || 'Price soon';
const availabilityLabel = primaryAvailability?.availability.label || 'Unavailable';
const canBuy = primaryAvailability?.canBuy ?? false;
const primaryActionClassName = canBuy
  ? buttonVariants({ size: 'lg' })
  : cn(
      buttonVariants({ size: 'lg', variant: 'outline' }),
      'pointer-events-none border-border/60 text-muted-foreground opacity-70',
    );
---

<SiteLayout
  pageTitle={`${storeItem.title} | Store`}
  pageDescription={storeItem.summary || `${storeItem.title} available through the BlackBox native storefront.`}
>
  <section class="layout-container pt-14 pb-6">
    <div class="grid gap-8 border border-border/70 bg-card/35 p-6 lg:grid-cols-[0.9fr_1.1fr] lg:p-8">
      <div class="relative overflow-hidden border border-border/60 bg-background/55">
        <Image
          src={storeItem.image}
          alt={storeItem.imageAlt}
          class="aspect-[4/5] h-full w-full object-cover"
          sizes="(min-width: 1024px) 40vw, 100vw"
        />
        <div class="absolute inset-0 bg-gradient-to-t from-black/78 via-black/10 to-transparent"></div>
        <div class="absolute inset-x-0 bottom-0 flex items-center justify-between gap-3 px-5 py-5">
          <div class="flex flex-wrap items-center gap-2 text-[10px] uppercase tracking-[0.18em] text-white/78">
            {storeItem.eyebrow && <span>{storeItem.eyebrow}</span>}
            <span class="text-white/55">{storeItem.sourceKind === 'release' ? 'BlackBox' : 'Distro'}</span>
          </div>
          <span
            class:list={[
              'inline-flex items-center border px-2 py-1 text-[10px] uppercase tracking-[0.18em]',
              canBuy
                ? 'border-white/25 bg-black/35 text-white/82'
                : 'border-white/15 bg-black/45 text-white/55',
            ]}
          >
            {availabilityLabel}
          </span>
        </div>
      </div>

      <div class="flex flex-col justify-between gap-8">
        <div class="space-y-5">
          <div class="flex flex-wrap items-center gap-3">
            <Badge variant="outline" className="border-border/70 bg-background/80 text-xs tracking-[0.15em] uppercase">
              Store
            </Badge>
            {metadataLabel && <p class="text-[11px] uppercase tracking-[0.18em] text-muted-foreground">{metadataLabel}</p>}
          </div>

          <div class="space-y-3">
            <h1 class="font-display text-5xl tracking-[0.08em] uppercase text-foreground sm:text-6xl">
              {storeItem.title.toUpperCase()}
            </h1>
            <p class="text-sm uppercase tracking-[0.13em] text-muted-foreground">{storeItem.subtitle}</p>
          </div>

          {storeItem.summary && <p class="max-w-2xl text-sm leading-relaxed text-muted-foreground">{storeItem.summary}</p>}

          <div class="grid gap-4 border border-border/60 bg-background/45 p-5 sm:grid-cols-2">
            <div class="space-y-2">
              <p class="text-[10px] uppercase tracking-[0.18em] text-muted-foreground">Offer</p>
              <p class="font-display text-2xl tracking-[0.08em] uppercase text-foreground">
                {storeItem.title}
              </p>
              {primaryAvailability?.optionLabel && (
                <p class="text-[11px] uppercase tracking-[0.16em] text-muted-foreground">{primaryAvailability.optionLabel}</p>
              )}
            </div>

            <div class="space-y-2">
              <p class="text-[10px] uppercase tracking-[0.18em] text-muted-foreground">Price</p>
              <p class="font-display text-3xl tracking-[0.08em] uppercase text-foreground">{priceLabel}</p>
              <p class="text-[11px] uppercase tracking-[0.16em] text-muted-foreground">{availabilityLabel}</p>
            </div>
          </div>
        </div>

        <div class="space-y-4 border-t border-border/60 pt-5">
          <div class="flex flex-wrap gap-3">
            <a href={storeItem.checkoutPath} data-astro-prefetch class={primaryActionClassName}>
              {canBuy ? 'Buy Now' : 'Currently Unavailable'}
            </a>
            <a
              href={createProjectRelativeUrl('/store/')}
              data-astro-prefetch
              class={cn(buttonVariants({ variant: 'outline', size: 'lg' }), 'uppercase tracking-[0.12em]')}
            >
              Back To Store
            </a>
          </div>

          <p class="text-sm leading-relaxed text-muted-foreground">
            {canBuy
              ? 'The same storefront contract feeds the collection page, this PDP, and the checkout shell that comes next.'
              : 'This item stays viewable even while it is resting. Availability remains explicit without dropping it out of the shelf.'}
          </p>
        </div>
      </div>
    </div>
  </section>
</SiteLayout>
