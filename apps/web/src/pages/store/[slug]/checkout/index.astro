---
import { Badge } from '@/components/ui/badge';
import { Card, CardContent } from '@/components/ui/card';
import CheckoutOrderSummary from '@/components/store/CheckoutOrderSummary';
import CheckoutOfferStatus from '@/components/store/CheckoutOfferStatus';
import StoreOfferPriceDisplay, { STORE_OFFER_PRICE_DISPLAY_COPY } from '@/components/store/StoreOfferPriceDisplay';
import { createProjectRelativeUrl } from '@/config/site';
import SiteLayout from '@/layouts/SiteLayout.astro';
import {
  createCartLineItemSnapshotForStorePage,
  createPricedCartSeedForStorePage,
  type StorePageEntry,
  createStorePageStaticPaths,
} from '@/lib/store-page-data';

export async function getStaticPaths() {
  return createStorePageStaticPaths();
}

interface Props {
  entry: StorePageEntry;
}

const { entry } = Astro.props;
const { storeItem, primaryAvailability } = entry;
const priceLabel = STORE_OFFER_PRICE_DISPLAY_COPY.loading;
const availabilityLabel = primaryAvailability?.availability.label || 'Unavailable';
const canBuy = primaryAvailability?.canBuy ?? false;
const fallbackLineItem = createCartLineItemSnapshotForStorePage(storeItem, primaryAvailability, storeItem.image.src);
const fallbackCartSeed = createPricedCartSeedForStorePage(storeItem, primaryAvailability, storeItem.image.src);
const initialCheckoutAvailability = {
  canBuy,
  label: availabilityLabel,
  optionLabel: primaryAvailability?.optionLabel ?? null,
  priceDisplay: priceLabel,
};
const summaryItem = {
  availabilityLabel,
  canBuy,
  image: storeItem.image.src,
  imageAlt: storeItem.imageAlt,
  itemHref: storeItem.storePath,
  optionLabel: primaryAvailability?.optionLabel ?? null,
  priceDisplay: priceLabel,
  storeItemSlug: storeItem.slug,
  subtitle: storeItem.subtitle,
  title: storeItem.title,
  variantId: primaryAvailability?.variantId ?? '',
};
---

<SiteLayout
  pageTitle={`${storeItem.title} Checkout | Store`}
  pageDescription={`Checkout for ${storeItem.title} by ${storeItem.subtitle}.`}
>
  <section class="layout-container pt-14 pb-8">
    <div class="mb-8 flex flex-wrap items-center justify-between gap-4">
      <div class="space-y-3">
        <Badge variant="outline" className="border-border/70 bg-background/80 text-xs tracking-[0.15em] uppercase">
          Checkout
        </Badge>
        <div class="space-y-2">
          <h1 class="font-display text-5xl tracking-[0.08em] uppercase text-foreground sm:text-6xl">Checkout</h1>
          <p class="max-w-2xl text-sm leading-relaxed text-muted-foreground">
            Review the item, confirm Greece-only shipping, then pay through Stripe.
          </p>
        </div>
      </div>
      <a
        href={createProjectRelativeUrl('/store/')}
        data-astro-prefetch
        class="text-[11px] font-semibold uppercase tracking-[0.18em] text-muted-foreground underline-offset-4 transition-colors hover:text-foreground hover:underline"
      >
        Continue Shopping
      </a>
    </div>

    <div
      class="grid min-w-0 grid-cols-1 gap-6 lg:grid-cols-[minmax(0,1fr)_24rem] xl:grid-cols-[minmax(40rem,1fr)_27rem]"
    >
      <div class="min-w-0 lg:hidden">
        <details class="group min-w-0 border border-border/70 bg-card/45" open>
          <summary
            class="flex cursor-pointer list-none items-center justify-between gap-3 px-4 py-4 text-[11px] font-semibold uppercase tracking-[0.18em] text-foreground marker:hidden sm:px-5"
          >
            <span class="min-w-0">Order Summary</span>
            <StoreOfferPriceDisplay
              client:load
              storeItemSlug={storeItem.slug}
              className="min-w-0 text-right font-display text-xl tracking-[0.08em] sm:text-2xl"
            />
          </summary>
          <div class="min-w-0 border-t border-border/70 p-3 sm:p-4">
            <CheckoutOrderSummary client:load {...summaryItem} />
          </div>
        </details>
      </div>

      <Card className="min-w-0 rounded-none border-border/70 bg-card/35 shadow-none">
        <CardContent className="grid min-w-0 grid-cols-1 gap-6 p-5 sm:p-6 lg:p-8">
          <div class="flex flex-wrap items-center justify-between gap-4 border-b border-border/60 pb-5">
            <div class="space-y-2">
              <p class="text-[10px] uppercase tracking-[0.2em] text-muted-foreground">Checkout</p>
              <h2 class="font-display text-4xl tracking-[0.08em] uppercase text-foreground">Shipping & Payment</h2>
            </div>
            <span class="text-[10px] uppercase tracking-[0.18em] text-muted-foreground">Secure Stripe Checkout</span>
          </div>

          <CheckoutOfferStatus
            client:load
            storeItemSlug={storeItem.slug}
            initialAvailability={initialCheckoutAvailability}
            fallbackLineItem={fallbackLineItem}
            fallbackCartSeed={fallbackCartSeed}
          />

          {
            !canBuy && (
              <p class="border border-border/70 bg-background/55 p-4 text-sm leading-relaxed text-muted-foreground">
                This item stays viewable, but checkout stays closed while it is unavailable.
              </p>
            )
          }
        </CardContent>
      </Card>

      <aside class="hidden lg:block">
        <div class="sticky top-[calc(var(--header-height)+2rem)]">
          <CheckoutOrderSummary client:load {...summaryItem} />
        </div>
      </aside>
    </div>
  </section>
</SiteLayout>
