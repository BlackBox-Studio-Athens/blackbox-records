---
import DistroCard from '@/components/cards/DistroCard.astro';
import SiteLayout from '@/layouts/SiteLayout.astro';
import { groupDistroEntries, listDistroEntries } from '@/lib/catalog-data';
import { getDistroPageContent } from '@/lib/site-data';

const [distroEntries, distroPageContent] = await Promise.all([listDistroEntries(), getDistroPageContent()]);
const groupedDistroEntries = groupDistroEntries(distroEntries);
const groupedDistroChunks = groupedDistroEntries.map((group) => ({
  ...group,
  chunks: group.entries.reduce<(typeof group.entries)[]>((chunks, entry, index) => {
    if (index % 6 === 0) chunks.push([]);
    chunks.at(-1)!.push(entry);
    return chunks;
  }, []),
}));
const eagerDistroEntryIds = new Set(distroEntries.slice(0, 3).map((entry) => entry.id));
---

<SiteLayout pageTitle={distroPageContent.page_title} pageDescription={distroPageContent.page_description}>
  <section class="layout-container distro-page-intro">
    <div class="distro-page-intro__surface">
      <p class="distro-page-intro__eyebrow">{distroPageContent.hero.section_label}</p>
      <h1 class="distro-page-intro__title">{distroPageContent.hero.title}</h1>
      <p class="distro-page-intro__copy">{distroPageContent.hero.intro}</p>
    </div>
  </section>

  <section class="layout-container distro-page-groups" aria-label="Distro">
    {
      groupedDistroChunks.map((group) => (
        <section
          class="distro-group-section"
          aria-labelledby={`distro-group-${group.groupName.toLowerCase().replace(/[^a-z0-9]+/g, '-')}`}
        >
          <div class="distro-group-section__header">
            <h2
              class="distro-group-section__title"
              id={`distro-group-${group.groupName.toLowerCase().replace(/[^a-z0-9]+/g, '-')}`}
            >
              {group.groupName}
            </h2>
            <p class="distro-group-section__copy">{distroPageContent.group_intros[group.introGroupName]}</p>
          </div>
          <div class="distro-group-chunks">
            {group.chunks.map((chunk) => (
              <div class="distro-group-grid distro-group-chunk">
                {chunk.map((item) => (
                  <DistroCard item={item} imageLoading={eagerDistroEntryIds.has(item.id) ? 'eager' : 'lazy'} />
                ))}
              </div>
            ))}
          </div>
        </section>
      ))
    }
  </section>
</SiteLayout>
