---
import { createProjectRelativeUrl } from '@/config/site';
import RedirectLayout from '@/layouts/RedirectLayout.astro';

const redirectUrl = createProjectRelativeUrl('/store/distro/');
---

<RedirectLayout
  pageTitle="Distro"
  pageDescription="Distro has moved into the BlackBox Records Store."
  preserveFragment
  redirectUrl={redirectUrl}
>
  <p class="text-sm leading-relaxed text-muted-foreground">
    Distro now lives in the Store. <a class="underline underline-offset-4" href={redirectUrl}>Browse Distro</a>.
  </p>
</RedirectLayout>
