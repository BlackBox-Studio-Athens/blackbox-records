# Safe default for ordinary local or secret-free static builds.
DECAP_BACKEND_MODE=disabled
DECAP_BRANCH=main

# Local mode. `pnpm cms:dev` owns these values and removes hosted-only settings.
CMS_DEV_PORT=4322
DECAP_LOCAL_PROXY_PORT=8082

# Hosted non-secret settings. GitHub Actions variables are authoritative.
DECAP_SITE_URL=https://blackbox-studio-athens.github.io/blackbox-records/
DECAP_REPOSITORY=BlackBox-Studio-Athens/blackbox-records
DECAPBRIDGE_BASE_URL=https://auth.decapbridge.com
DECAPBRIDGE_GATEWAY_URL=https://gateway.decapbridge.com

# Hosted endpoint secrets. These placeholders are intentionally rejected by
# `pnpm cms:hosted:preflight`; replace them only in GitHub Actions Secrets.
DECAPBRIDGE_AUTH_ENDPOINT=/sites/__SET_DECAPBRIDGE_SITE_ID__/pkce
DECAPBRIDGE_AUTH_TOKEN_ENDPOINT=/sites/__SET_DECAPBRIDGE_SITE_ID__/token
