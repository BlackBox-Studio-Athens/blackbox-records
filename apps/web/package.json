{
  "name": "@blackbox/web",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "clean:dev-cache": "node -e \"const fs=require('node:fs');for (const p of ['.astro','node_modules/.astro','node_modules/.vite']) fs.rmSync(p,{recursive:true,force:true});\"",
    "cms:dev": "node scripts/start-cms-dev.mjs",
    "cms:proxy": "node scripts/start-decap-proxy.mjs",
    "dev": "astro dev --root .",
    "dev:clean": "npm run clean:dev-cache && astro dev --root .",
    "build": "astro build --root .",
    "preview": "astro preview --root .",
    "check": "astro check --root .",
    "test:unit": "vitest run",
    "astro": "astro"
  },
  "dependencies": {
    "@blackbox/api-client": "workspace:*",
    "@astrojs/react": "^5.0.3",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-slot": "^1.2.4",
    "@tailwindcss/vite": "^4.2.2",
    "astro": "^6.1.8",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "fuse.js": "^7.3.0",
    "lucide-react": "^1.8.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "sharp": "^0.34.5",
    "tailwind-merge": "^3.4.0",
    "tailwindcss": "^4.2.2",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.8",
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.2",
    "@types/react-dom": "^19.2.2",
    "decap-server": "^3.7.0",
    "shadcn": "^4.3.1",
    "typescript": "^5.9.3",
    "vitest": "^4.1.4"
  }
}
