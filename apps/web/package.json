{
  "name": "@blackbox/web",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "clean:dev-cache": "node -e \"const fs=require('node:fs');for (const p of ['.astro','node_modules/.astro','node_modules/.vite']) fs.rmSync(p,{recursive:true,force:true});\"",
    "cms:dev": "node scripts/start-cms-dev.mjs",
    "cms:proxy": "node scripts/start-decap-proxy.mjs",
    "dev": "astro dev --root .",
    "dev:static": "node scripts/start-static-site-dev.mjs",
    "dev:bg": "astro dev --root . --host 127.0.0.1 --port 4321 --background",
    "dev:status": "astro dev status",
    "dev:logs": "astro dev logs",
    "dev:stop": "astro dev stop",
    "dev:clean": "pnpm clean:dev-cache && astro dev --root .",
    "assets:check": "tsx scripts/check-assets.ts",
    "cache:policy:check": "tsx scripts/check-static-cache-policy.ts",
    "cache:policy:hosted-audit": "tsx scripts/check-hosted-cache-policy.ts",
    "brand-font:check": "tsx scripts/check-brand-font.ts",
    "image-markup:check": "tsx scripts/check-image-markup.ts",
    "prd:holding:prepare": "tsx scripts/prepare-prd-holding.ts",
    "prd:holding:check": "tsx scripts/check-prd-holding.ts",
    "build": "astro build --root . && pnpm cache:policy:check && pnpm brand-font:check && pnpm image-markup:check",
    "preview": "astro preview --root .",
    "check": "astro check --root .",
    "test": "vitest run",
    "test:unit": "vitest run",
    "astro": "astro"
  },
  "dependencies": {
    "@astrojs/react": "^6.0.0",
    "@blackbox/api-client": "workspace:*",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-slot": "^1.2.4",
    "@sindresorhus/slugify": "^3.0.0",
    "@tailwindcss/vite": "^4.3.0",
    "astro": "^7.0.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "fuse.js": "^7.3.0",
    "lucide-react": "^1.16.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "robot3": "^1.2.0",
    "sharp": "^0.34.5",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "^4.3.0",
    "tw-animate-css": "^1.4.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@astrojs/check": "0.9.9",
    "@types/node": "^25.9.1",
    "@types/react": "19.2.15",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "^5.2.0",
    "decap-server": "^3.7.0",
    "msw": "2.14.6",
    "shadcn": "^4.8.0",
    "typescript": "^5.9.3",
    "vitest": "4.1.7"
  }
}
