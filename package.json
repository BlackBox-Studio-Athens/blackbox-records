{
  "name": "blackbox-records",
  "version": "1.0.0",
  "private": true,
  "packageManager": "pnpm@10.33.4",
  "scripts": {
    "dev": "pnpm dev:web",
    "dev:web": "pnpm --filter @blackbox/web dev",
    "site:dev": "pnpm --filter @blackbox/web dev:static",
    "dev:clean": "pnpm --filter @blackbox/web dev:clean",
    "cms:dev": "pnpm --filter @blackbox/web cms:dev",
    "cms:proxy": "pnpm --filter @blackbox/web cms:proxy",
    "dev:backend": "pnpm --filter @blackbox/backend dev",
    "dev:backend:mock": "pnpm --filter @blackbox/backend dev:mock",
    "dev:backend:sandbox": "pnpm --filter @blackbox/backend dev:sandbox",
    "stripe-mock:local": "tsx scripts/start-stripe-mock.ts",
    "dev:stack:stripe-test": "tsx scripts/start-local-stack.ts stripe-test",
    "dev:stack:stripe-mock": "tsx scripts/start-local-stack.ts stripe-mock",
    "dev:stack:stripe-mock-api": "tsx scripts/start-local-stack.ts stripe-mock-api",
    "dev:stack:uat-connected": "tsx scripts/start-local-stack.ts uat-connected",
    "checkout:preflight:stripe-test": "tsx scripts/check-stripe-test-checkout.ts",
    "stripe:catalog:verify": "tsx scripts/stripe-catalog-verify.ts",
    "stripe:catalog:reset-sandbox": "pnpm --filter @blackbox/backend exec tsx scripts/stripe-catalog-reset-sandbox.ts",
    "stripe:catalog:artifacts:generate": "tsx scripts/generate-stripe-uat-catalog-artifacts.ts --write",
    "stripe:catalog:artifacts:check": "tsx scripts/generate-stripe-uat-catalog-artifacts.ts --check",
    "production:catalog-readiness:check": "tsx scripts/check-production-catalog-readiness.ts",
    "catalog:checkout:pause": "tsx scripts/pause-catalog-checkout.ts",
    "runtime:config:verify": "tsx scripts/verify-runtime-config.ts",
    "environment:model:verify": "tsx scripts/verify-environment-model.ts",
    "stripe:payment-methods:verify": "tsx scripts/verify-stripe-payment-method-configuration.ts",
    "stripe:webhooks:verify": "tsx scripts/verify-stripe-webhook-endpoints.ts",
    "smoke:stripe-sandbox": "tsx scripts/smoke-stripe-sandbox.ts",
    "smoke:stripe-promotion": "tsx scripts/smoke-stripe-promotion.ts",
    "stripe:webhook:simulate:local": "pnpm --filter @blackbox/backend webhook:simulate:local",
    "openspec:guard": "tsx scripts/assert-openspec-worktree.ts",
    "openspec": "tsx scripts/run-openspec.ts",
    "openspec:readonly": "pnpm openspec",
    "deploy:backend:sandbox": "pnpm --filter @blackbox/backend deploy:sandbox",
    "deploy:backend:production": "pnpm --filter @blackbox/backend deploy:production",
    "worker:dev": "pnpm dev:backend",
    "worker:dev:sandbox": "pnpm dev:backend:sandbox",
    "build": "pnpm build:web",
    "build:web": "pnpm --filter @blackbox/web build",
    "generate:api": "pnpm --filter @blackbox/backend generate:openapi && pnpm --filter @blackbox/api-client generate",
    "assets:check": "pnpm --filter @blackbox/web assets:check",
    "audit:commerce-boundaries": "tsx scripts/audit-commerce-boundaries.ts",
    "audit:module-boundaries": "tsx scripts/audit-module-boundaries.ts",
    "audit:unused": "knip --config knip.jsonc --no-exit-code --no-config-hints",
    "renovate:validate": "pnpm dlx --package renovate renovate-config-validator --strict",
    "preview": "pnpm --filter @blackbox/web preview",
    "format": "prettier . --write",
    "format:check": "prettier . --check",
    "lint": "eslint . --max-warnings=0",
    "lint:fix": "eslint . --fix",
    "check": "pnpm stripe:catalog:artifacts:check && pnpm environment:model:verify && pnpm format:check && pnpm lint && pnpm check:types && pnpm check:boundaries",
    "check:boundaries": "pnpm audit:module-boundaries && pnpm depcruise:boundaries && pnpm audit:commerce-boundaries",
    "check:types": "pnpm --parallel --filter @blackbox/web --filter @blackbox/backend --filter @blackbox/api-client check",
    "check:web": "pnpm --filter @blackbox/web check",
    "check:backend": "pnpm --filter @blackbox/backend check",
    "check:api-client": "pnpm --filter @blackbox/api-client check",
    "test:unit": "pnpm --parallel --filter @blackbox/web --filter @blackbox/backend --filter @blackbox/api-client test",
    "test:app-shell": "pnpm --filter @blackbox/web exec vitest run src/components/app-shell",
    "test:cms-admin": "pnpm --filter @blackbox/web exec vitest run src/lib/admin",
    "test:web": "pnpm --filter @blackbox/web test:unit",
    "test:backend": "pnpm --filter @blackbox/backend test",
    "test:api-client": "pnpm --filter @blackbox/api-client test",
    "depcruise:boundaries": "depcruise --config .dependency-cruiser.cjs apps/web/src apps/backend/src packages/api-client/src"
  },
  "devDependencies": {
    "@astrojs/check": "0.9.9",
    "@eslint/js": "^10.0.1",
    "@t3-oss/env-core": "^0.13.11",
    "astro": "6.4.2",
    "dependency-cruiser": "^17.4.0",
    "eslint": "^10.4.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-astro": "^1.7.0",
    "eslint-plugin-boundaries": "^6.0.2",
    "execa": "9.6.1",
    "knip": "^6.14.2",
    "playwright": "1.60.0",
    "prettier": "^3.8.3",
    "prettier-plugin-astro": "0.14.1",
    "tsx": "4.22.3",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.59.4",
    "zod": "^4.4.3"
  }
}
