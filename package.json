{
  "name": "blackbox-records",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.29.3",
  "scripts": {
    "clean:dev-cache": "node -e \"const fs=require('node:fs');for (const p of ['.astro','node_modules/.astro','node_modules/.vite']) fs.rmSync(p,{recursive:true,force:true});\"",
    "cms:dev": "node scripts/start-cms-dev.mjs",
    "cms:proxy": "node scripts/start-decap-proxy.mjs",
    "dev": "astro dev",
    "dev:clean": "npm run clean:dev-cache && astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "check": "astro check",
    "test:unit": "vitest run",
    "astro": "astro"
  },
  "dependencies": {
    "@astrojs/react": "^4.4.2",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-slot": "^1.2.4",
    "@tailwindcss/vite": "^4.1.18",
    "astro": "^5.18.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "fuse.js": "^7.1.0",
    "lucide-react": "^0.563.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "sharp": "^0.34.5",
    "tailwind-merge": "^3.4.0",
    "tailwindcss": "^4.1.18",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.6",
    "@types/react": "^19.2.2",
    "@types/react-dom": "^19.2.2",
    "decap-server": "^3.5.2",
